# justfile — canonical task runner for {{ project_name }}.
# Run `just --list` to see all available recipes.

set shell := ["bash", "-uc"]

# Run verification (Phase 2: --quick, --full, --no-cache, --format, --check)
verify *FLAGS:
    uv run verify-kit verify {% raw %}{{FLAGS}}{% endraw %}

# Run linters (ruff for Python, biome for JS/TS) over the project
lint:
    uv run ruff check .
    @command -v pnpm >/dev/null 2>&1 && pnpm dlx @biomejs/biome check . || true

# Auto-format Python and JS/TS
format:
    uv run ruff format .
    @command -v pnpm >/dev/null 2>&1 && pnpm dlx @biomejs/biome format --write . || true

# Drop into a subshell with the mise-managed env activated
shell:
    mise exec -- $SHELL

# Wipe the cache and report files (Phase 2: .verify/)
verify-clean:
    rm -rf .verify

# Start Jaeger all-in-one for trace inspection at http://localhost:16686
trace-up:
    @echo "Starting Jaeger UI at http://localhost:16686 ..."
    docker run -d --rm \
        --name verify-kit-jaeger \
        -e COLLECTOR_OTLP_ENABLED=true \
        -p 16686:16686 -p 4317:4317 -p 4318:4318 \
        jaegertracing/all-in-one:1.76.0

# Stop the Jaeger container
trace-down:
    docker stop verify-kit-jaeger 2>/dev/null || true

# Render the most recent verify-kit trace (requires `just trace-up` first)
trace *FLAGS:
    OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317 \
        uv run verify-kit trace {% raw %}{{FLAGS}}{% endraw %}

# Start the verify-kit MCP server over stdio (default) or pass --http etc.
mcp *ARGS:
    uv run verify-kit mcp serve {% raw %}{{ARGS}}{% endraw %}

# Start the verify-kit MCP server over HTTP with bearer-token auth.
mcp-http port='7878' token='':
    uv run verify-kit mcp serve --http :{% raw %}{{port}}{% endraw %} --token={% raw %}{{token}}{% endraw %}

{% if has_web and has_backend %}
# Run Vite (:5173) and FastAPI (:8000) side-by-side. Ctrl-C kills both.
dev:
	mprocs "pnpm --dir web dev" "uv run uvicorn app.main:app --reload --port 8000"
{% elif has_web %}
# Frontend-only mode (D-W04): consumer brings their own backend.
dev:
	pnpm --dir web dev
{% elif has_backend %}
dev:
	uv run uvicorn app.main:app --reload --port 8000
{% endif %}

{% if has_backend %}
# Run the FastAPI app under uvicorn (dev mode, auto-reload)
serve:
    uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

# Run the backend test slice (unit + integration)
test-backend:
    uv run pytest tests/backend/ -v

# Bring up the full local stack: api + postgres + jaeger.
# `--build` forces a rebuild so source changes in app/* land in the image —
# without it, docker reuses a cached image even when app code changed, which
# was producing stale-API false failures in the verify-backend integration test.
docker-up:
    docker compose up -d --build --wait --wait-timeout 120

# Stop and remove the stack including volumes
docker-down:
    docker compose down -v

# Run the FULL backend verify slice: bring up stack, fuzz live OpenAPI, smoke,
# tear down. This is the ground truth for phase success criterion 3 — schemathesis
# MUST run against the live OpenAPI. Use `verify-backend-quick` for local UX
# without the docker overhead.
#
# Cleanup discipline: the `trap` registered as the first script statement runs
# `docker compose down -v --remove-orphans` on EVERY exit path (success,
# failure, Ctrl-C). Without it, a mid-recipe failure (pytest red, schemathesis
# crash, network blip) leaves the docker stack running and orphan containers
# accumulate across runs.
verify-backend:
    #!/usr/bin/env bash
    set -e
    # Project name = basename(cwd), lower-cased — matches docker-compose's
    # default project derivation. Using `-p` lets the trap tear down by
    # project label even if docker-compose.yml itself is unparseable
    # (which is the actual r7v failure mode: a broken compose file made
    # `docker compose down` exit non-zero, the trap's `|| true` swallowed
    # it, and containers leaked).
    _vk_project="$(basename "$PWD" | tr '[:upper:]' '[:lower:]')"
    trap 'docker compose -p "$_vk_project" down -v --remove-orphans >/dev/null 2>&1 || true' EXIT
    echo "[verify-backend] bringing up stack (api + postgres + jaeger)..."
    just docker-up
    echo "[verify-backend] running pytest backend slice..."
    uv run pytest tests/backend/ -v
    echo "[verify-backend] running schemathesis fuzz against LIVE OpenAPI..."
    uv run schemathesis run http://localhost:8000/openapi.json --checks all --max-examples 20 --max-response-time 2
    echo "[verify-backend] smoke: /healthz"
    curl -sf http://localhost:8000/healthz
    echo "[verify-backend] smoke: /__debug/state (ENV=dev only)"
    curl -sf http://localhost:8000/__debug/state || echo "  (skipped — ENV != dev or no state file)"
    echo "[verify-backend] tearing down stack (trap will also fire on exit)..."
    just docker-down
    echo "[verify-backend] OK"

# Quick local-UX path: skip stack startup. Runs pytest + opportunistic fuzz if
# the app happens to already be reachable. Does NOT prove success criterion 3
# — use `just verify-backend` for that.
verify-backend-quick:
    uv run pytest tests/backend/ -v
    @if curl -sf http://localhost:8000/healthz >/dev/null 2>&1; then \
        echo "[verify-backend-quick] app reachable — opportunistic fuzz"; \
        uv run schemathesis run http://localhost:8000/openapi.json --checks all --max-examples 20 --max-response-time 2; \
    else \
        echo "[verify-backend-quick] app not running on :8000 — pytest only (use \`just verify-backend\` for full slice)"; \
    fi
{% endif %}

{% if has_web %}
# Run all web add-on checks (vitest, playwright, lighthouse, axe, lost_pixel).
# Lighthouse + Lost Pixel are tier=slow — included here; use verify-web-quick to skip them.
# CLI does exact match per --check (template/harness/core.py.jinja2:101); enumeration is mandatory.
verify-web:
	uv run verify-kit verify --check=web.vitest --check=web.playwright --check=web.lighthouse --check=web.axe --check=web.lost_pixel

# Fast feedback loop: only standard-tier web checks (vitest, playwright, axe).
verify-web-quick:
	uv run verify-kit verify --check=web.vitest --check=web.playwright --check=web.axe

# Headed-mode Playwright smoke; useful for visual debugging during development.
smoke-web:
	cd web && pnpm exec playwright test --headed

# Capture/refresh Lost Pixel baselines inside the pinned Docker image (D-W02).
# Uses Lost Pixel's built-in `lost-pixel docker update` mode which owns the
# container, pulls its own image, and serves dist/ internally — no host
# dep directory mount required (verify-kit-c7k: host arm64 binaries crash linux).
# Run this after intentional visual changes; review the new PNGs; commit with `git add`.
web-baseline:
	pnpm --dir web build
	cd web && pnpm exec lost-pixel docker update
{% endif %}

{% if has_llm %}
# Opt-in eval gate (D-15) — NOT called by `just verify`. Writes machine-readable
# results to .verify/eval-results.json for the verify-kit-eval SKILL.md to
# consume. Requires Node + pnpm + ANTHROPIC_API_KEY.
eval:
    mkdir -p .verify
    pnpm dlx promptfoo eval -c eval/promptfoo.config.yaml -o .verify/eval-results.json
    @echo "[eval] results written to .verify/eval-results.json"

# WARNING: hits the live LLM API to re-record cassettes; requires
# ANTHROPIC_API_KEY set and consumes real tokens. After running, cassette-backed
# tests (test_autoevals.py etc.) will be exercised instead of skipped by the
# autouse skip-when-no-cassette guard.
refresh-cassettes:
    rm -rf tests/llm/cassettes/
    uv run pytest tests/llm/ --record-mode=once
{% endif %}
