"""Business logic shared by the HTTP routes and the CLI commands."""

from __future__ import annotations

from datetime import UTC, datetime

from app.models import EchoRequest, EchoResponse


def echo(req: EchoRequest, request_id: str) -> EchoResponse:
    """Pure function — shared by HTTP route and CLI command (API-09)."""
    return EchoResponse(
        message=req.message,
        request_id=request_id,
        received_at=datetime.now(tz=UTC),
    )
