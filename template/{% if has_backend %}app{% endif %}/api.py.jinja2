router = APIRouter()


@router.get("/healthz", response_model=HealthResponse)
async def healthz(request: Request) -> HealthResponse:
    settings = request.app.state.settings
    return HealthResponse(status="ok", version="0.1.0", env=settings.ENV)


@router.post(
    "/echo",
    response_model=EchoResponse,
    responses={
        # FastAPI returns 400 when the request body fails JSON parsing (before the
        # Pydantic validator can run); without this declaration, schemathesis flags
        # 400 as an undocumented status code.
        400: {"description": "Malformed request body (JSON parse failure)"},
    },
)
async def echo_route(req: EchoRequest) -> EchoResponse:
    rid = correlation_id.get() or "no-correlation-id"
    return echo(req, request_id=rid)


@router.get(
    "/events/stream",
    # SSE streams text/event-stream; FastAPI's default JSONResponse Content-Type
    # in the schema would otherwise misadvertise this route.
    responses={200: {"content": {"text/event-stream": {}}}},
)
async def events_stream() -> EventSourceResponse:
    async def gen():
        for i in range(3):
            await asyncio.sleep(0.01)
            yield {"event": "tick", "data": str(i)}

    return EventSourceResponse(gen())


@router.get("/trace-demo")
async def trace_demo(request: Request):
    """Demonstrate the OTel distributed trace waterfall.

    Performs a real DB query when has_db=true so SQLAlchemyInstrumentor emits a
    child DB span (producing the full browser → FastAPI → DB waterfall). Degrades
    gracefully to {"db": false} when the database is unreachable (e.g. fuzzed
    in-process with no live DB) so the route is always safe to hit — it never
    returns a 5xx. The engine/sessionmaker live on app.state (set in lifespan);
    this route never constructs its own engine.
    """
{% if has_db %}
    from sqlalchemy import text
    from sqlalchemy.exc import SQLAlchemyError

    sessionmaker = getattr(request.app.state, "sessionmaker", None)
    if sessionmaker is None:
        return {"db": False, "result": None}
    try:
        async with sessionmaker() as session:
            result = await session.execute(text("SELECT 1"))
            row = result.scalar()
    except (SQLAlchemyError, OSError):
        # OSError covers connect-refused / DNS / timeout — asyncpg raises a raw
        # OSError at connect time before SQLAlchemy wraps it; SQLAlchemyError
        # covers query/DB-layer errors. Degrade to a clean 200 so the route is
        # always safe to fuzz (the in-process schemathesis check has no live DB).
        return {"db": False, "result": None}
    return {"db": True, "result": row}
{% else %}
    return {"db": False}
{% endif %}
{% if has_llm %}


# Starter-grade prompt-injection defenses for /summarize. These are layered
# checks that run at Pydantic validation time, BEFORE the LLM call:
#   1. Length cap (Field max_length=5000) — bounds cost runaway (T-06-08).
#   2. Control-char strip — removes zero-width / null bytes that could
#      smuggle injection markers past the denylist (T-06-09).
#   3. Static injection-marker denylist — catches the three obvious shapes
#      (T-06-07). NOT bulletproof: per OWASP LLM01, prompt injection cannot
#      be fully prevented by input filtering alone; consumers MUST add
#      output filtering + classifier prefilter + system-prompt sandwiching
#      for production use. See README LLM section for the full caveat.
#   4. Content-Type enforcement — Pydantic-typed request param means
#      FastAPI returns 422 for non-JSON Content-Type by default.
_CONTROL_CHARS = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")
_INJECTION_MARKERS = [
    re.compile(r"(?i)\b(ignore|disregard|forget)\s+(all\s+)?previous\s+(instructions|prompts)"),
    re.compile(r"<\|im_(start|end)\|>"),
    re.compile(r"(?i)###\s*system\b"),
]


class SummarizeRequest(BaseModel):
    text: str = Field(
        ..., min_length=1, max_length=5000, description="Text to summarize in one sentence."
    )

    @field_validator("text")
    @classmethod
    def _strip_and_check(cls, v: str) -> str:
        v = _CONTROL_CHARS.sub("", v)
        for marker in _INJECTION_MARKERS:
            if marker.search(v):
                raise ValueError("input contains a disallowed pattern")
        return v


class SummarizeResponse(BaseModel):
    summary: str
    cost_usd: float
    latency_ms: float


# Decorator-ordering rule (Pitfall 3, see harness/llm.py module docstring):
# @cost_budget MUST be the OUTER decorator. call_llm is itself @llm_call-
# decorated internally, so the effective stack is
#   @cost_budget OUTER -> call_llm -> @llm_call INNER -> adapter.
# The budget check fires AFTER the recorded cost lands in the contextvar.
@cost_budget(usd=0.05, on_exceed="raise")
async def _summarize(text: str) -> dict:
    prompt = f"Summarize the following text in one sentence: {text}"
    # call_llm returns a dict shaped per the 05-02 adapter contract
    # ({content, usage, cost_usd, model, response_model, provider, retry_count}).
    # Do NOT reference an .output attribute — call_llm yields a dict, not a
    # pydantic-ai AgentRunResult.
    return await call_llm(prompt, model="anthropic/claude-haiku-4-5")


@router.post(
    "/summarize",
    response_model=SummarizeResponse,
    responses={
        # FastAPI returns 400 when the request body fails JSON parsing (before
        # Pydantic runs); declare it so schema-fuzz does not flag it as an
        # undocumented status code. Mirrors /echo's responses declaration.
        400: {"description": "Malformed request body (JSON parse failure)"},
    },
)
async def summarize_route(req: SummarizeRequest) -> SummarizeResponse:
    started = monotonic()
    out = await _summarize(req.text)
    latency_ms = (monotonic() - started) * 1000.0
    # Pitfall 5: claude-agent-sdk routing path reports cost_usd=0.0 because
    # the SDK does not expose token usage; the operator's real cost is in
    # their Claude Code / Claude Max account dashboard. README LLM section
    # documents this asymmetry.
    return SummarizeResponse(
        summary=out["content"],
        cost_usd=float(out.get("cost_usd", 0.0)),
        latency_ms=latency_ms,
    )
{% endif %}
