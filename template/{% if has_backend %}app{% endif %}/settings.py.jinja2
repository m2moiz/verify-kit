"""Application settings model and loader backed by environment and .env files."""

from __future__ import annotations

from pathlib import Path

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """Application settings loaded from environment + .env file.

    NEVER reads Path.cwd() — see REVIEW-CHECKLIST §1. The caller is responsible
    for passing _env_file via load(cwd=...) below.
    """

    model_config = SettingsConfigDict(env_file=None, extra="ignore")

    ENV: str = Field(default="dev", description="dev | prod | test")
    LOG_LEVEL: str = Field(default="INFO")
    LOG_FORMAT: str = Field(default="auto")
    {% if has_db %}
    DATABASE_URL: str = Field(default="postgresql+asyncpg://postgres:postgres@localhost:5432/app")
    {% endif %}
    PROFILE_ENABLED: bool = Field(default=True, description="dev-only pyinstrument toggle")
{% if has_web %}
    CORS_ALLOW_ORIGINS: list[str] = Field(
        default=["http://localhost:5173", "http://localhost:3000", "http://localhost:4173"],
        description="Allowed CORS origins. In production, restrict to your actual frontend URL.",
    )

    @property
    def cors_allow_origins(self) -> list[str]:
        """Return the configured list of allowed CORS origins."""
        return self.CORS_ALLOW_ORIGINS

{% endif %}
    VERIFYKIT_AUTH_TOKEN: str | None = Field(
        default=None,
        description="X-VerifyKit-Token header value; unset enables dev fallback when ENV='dev'",
    )

    def assert_deploy_ready(self) -> None:
        """Raise if this configuration is unsafe to ship to production.

        Deploy-readiness guard — fail closed. This is deliberately NOT a
        construction-time validator: normal ``Settings()`` stays boot-tolerant
        so ``/healthz`` keeps answering even in a misconfigured prod (the auth
        dependency returns 503 at request time — see app/auth.py). This method
        is the explicit *pre-deploy* check: a production environment MUST set
        VERIFYKIT_AUTH_TOKEN, otherwise every authenticated route falls back to
        a 503 and the API is effectively unusable once shipped.

        The ``deploy.config`` harness check calls this against a synthetic
        prod/no-token configuration and asserts it raises. Remove or weaken this
        guard and ``deploy.config`` goes red (fail-open detected).
        """
        if self.ENV in {"prod", "production"} and not self.VERIFYKIT_AUTH_TOKEN:
            raise ValueError(
                "ENV=prod requires VERIFYKIT_AUTH_TOKEN to be set — refusing to "
                "certify a production deploy with authentication unconfigured."
            )


def load(cwd: Path) -> Settings:
    """Load Settings, reading .env relative to the explicit cwd argument.

    Passes cwd / ".env" as the env_file; never resolves against process cwd.
    """
    # `_env_file` is a documented pydantic-settings init kwarg handled via the
    # BaseSettings metaclass; pyright cannot see it in the signature (known
    # false positive, not a bug). Coded suppression keeps `typecheck.python` green.
    return Settings(_env_file=cwd / ".env" if (cwd / ".env").exists() else None)  # pyright: ignore[reportCallIssue]
