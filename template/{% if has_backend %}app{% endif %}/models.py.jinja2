from __future__ import annotations

import re
from datetime import datetime

from pydantic import BaseModel, Field, field_validator


class HealthResponse(BaseModel):
    """GET /healthz response. Single source of truth — the verify-backend
    check asserts against this class directly so the response shape and the
    assertion cannot drift."""

    status: str = Field(default="ok")
    version: str
    env: str


# Starter-grade input hardening for /echo. Distinct from /summarize's
# _CONTROL_CHARS in app/api.py: /echo does NOT call an LLM, so the injection-
# marker denylist is deliberately omitted (would generate false positives on
# legitimate user input). Layers applied:
#   1. Length cap (Field max_length=5000) — bounds memory pressure (T-06-11).
#   2. Control-char strip — removes zero-width / null bytes that could smuggle
#      markers through downstream log parsers (T-06-12).
#   3. Content-Type enforcement — Pydantic-typed request param means FastAPI
#      returns 422 for non-JSON Content-Type by default.
_CONTROL_CHARS_ECHO = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")


class EchoRequest(BaseModel):
    message: str = Field(min_length=1, max_length=5000)

    @field_validator("message")
    @classmethod
    def _strip_control(cls, v: str) -> str:
        return _CONTROL_CHARS_ECHO.sub("", v)


class EchoResponse(BaseModel):
    message: str
    request_id: str
    received_at: datetime
