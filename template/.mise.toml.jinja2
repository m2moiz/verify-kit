# .mise.toml — toolchain version pins for verify-kit scaffolded projects.
#
# Pinning Python 3.13+ and Node 24+ is required for the verify-kit harness:
# - Python 3.13 is the minimum for stdlib tomllib, PEP 695 type aliases, and
#   other harness internals.
# - Node 24 is the minimum for ESM-first pnpm workspaces and Biome 2.x.
# - uv handles all Python deps (uv sync / uv run); do NOT install Python deps
#   via pip directly — uv enforces venv discipline via uv.lock.
# - pnpm handles Node deps when JS/TS files are present; otherwise unused.
#   pnpm is pinned to an EXACT version that MUST match web/package.json's
#   `packageManager` field (corepack refuses to switch versions: a `latest`
#   here installs a newer major than the pin, and any corepack-mediated `pnpm`
#   call — including the harness web build subprocess — then errors with
#   "pnpm does not switch versions under corepack". Keep these two pins
#   identical and aligned with web/pnpm-lock.yaml's lockfileVersion.

[tools]
python = "3.13"
node = "24"
uv = "latest"
just = "latest"
pnpm = "9.15.0"
# gitleaks powers the always-on security.secrets check + the pre-commit hook.
"aqua:gitleaks/gitleaks" = "8.30.1"
{% if has_web and has_backend %}
"npm:mprocs" = "latest"
{% endif %}

[env]
PYTHONDONTWRITEBYTECODE = "1"
