name: ci
"on": [push, pull_request]
jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: jdx/mise-action@v2
        with:
          cache: true
      - uses: actions/cache@v4
        with:
          path: |
            ~/.cache/uv
            ~/.cache/pnpm
            ~/.cache/pre-commit
          key: {% raw %}deps-${{ runner.os }}-${{ hashFiles('uv.lock','pnpm-lock.yaml','.pre-commit-config.yaml') }}{% endraw %}

      - run: uv sync && just verify
