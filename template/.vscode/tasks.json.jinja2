{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "verify",
      "type": "shell",
      "command": "just verify",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$verify-kit-ruff", "$verify-kit-pyright", "$tsc", "$verify-kit-biome"]
    },
    {
      "label": "verify --quick",
      "type": "shell",
      "command": "just verify --quick",
      "problemMatcher": ["$verify-kit-ruff", "$verify-kit-pyright", "$tsc", "$verify-kit-biome"]
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "just lint",
      "problemMatcher": ["$verify-kit-ruff", "$verify-kit-biome"]
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "just typecheck",
      "problemMatcher": ["$verify-kit-pyright", "$tsc"]
    }
  ],
  "inputs": [],
  // Custom problem matchers exposed via the `$verify-kit-*` names referenced above.
  "problemMatchers": [
    {
      "name": "verify-kit-ruff",
      "owner": "ruff",
      "source": "Ruff",
      "fileLocation": ["relative", "${workspaceFolder}"],
      "pattern": {
        "regexp": "^(.+?):(\\d+):(\\d+):\\s+([A-Z]\\d+)\\s+(.*)$",
        "file": 1, "line": 2, "column": 3, "code": 4, "message": 5
      }
    },
    {
      "name": "verify-kit-pyright",
      "owner": "pyright",
      "source": "Pyright",
      "fileLocation": "autoDetect",
      "pattern": {
        "regexp": "^\\s*(.+?):(\\d+):(\\d+)\\s+-\\s+(error|warning|information):\\s+(.*?)(?:\\s+\\(([\\w-]+)\\))?$",
        "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5, "code": 6
      }
    },
    {
      "name": "verify-kit-biome",
      "owner": "biome",
      "source": "Biome",
      "fileLocation": ["relative", "${workspaceFolder}"],
      "pattern": {
        "regexp": "^::(error|warning) file=(.+?),line=(\\d+),col=(\\d+)::(.+)$",
        "severity": 1, "file": 2, "line": 3, "column": 4, "message": 5
      }
    }
  ]
}
