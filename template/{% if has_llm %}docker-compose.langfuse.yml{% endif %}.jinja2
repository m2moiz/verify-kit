# docker-compose.langfuse.yml — self-host Langfuse stack for {{ project_name }}.
#
# Brings up langfuse-web + langfuse-worker + postgres + clickhouse + redis on
# an isolated bridge network so the Phase 4 docker-compose.yml (api + jaeger
# + postgres) does not accidentally cross-connect. Total memory footprint
# ~900 MB (D-07).
#
# Security: langfuse-web binds to 127.0.0.1 only (loopback). For remote
# access use Tailscale or another tunnel — do NOT change the binding to
# 0.0.0.0:3000 (threat T-05-12).
#
# Bring up:   docker compose -f docker-compose.langfuse.yml up -d
# Tear down:  docker compose -f docker-compose.langfuse.yml down -v

services:
  langfuse-web:
    image: langfuse/langfuse:3
    depends_on:
      postgres:
        condition: service_healthy
      clickhouse:
        condition: service_healthy
      redis:
        condition: service_healthy
    ports:
      - "127.0.0.1:3000:3000"
    environment:
      DATABASE_URL: postgresql://langfuse:langfuse@postgres:5432/langfuse
      CLICKHOUSE_URL: http://clickhouse:8123
      CLICKHOUSE_USER: clickhouse
      CLICKHOUSE_PASSWORD: clickhouse
      REDIS_HOST: redis
      REDIS_PORT: 6379
      SALT: ${LANGFUSE_SALT:?LANGFUSE_SALT must be set; generate with: openssl rand -base64 32}
      ENCRYPTION_KEY: ${LANGFUSE_ENCRYPTION_KEY:?LANGFUSE_ENCRYPTION_KEY must be set; generate with: openssl rand -hex 32}
      NEXTAUTH_SECRET: ${LANGFUSE_NEXTAUTH_SECRET:?LANGFUSE_NEXTAUTH_SECRET must be set; generate with: openssl rand -base64 32}
      NEXTAUTH_URL: http://localhost:3000
      LANGFUSE_PUBLIC_KEY: ${LANGFUSE_PUBLIC_KEY:-}
      LANGFUSE_SECRET_KEY: ${LANGFUSE_SECRET_KEY:-}
    networks:
      - langfuse-net

  langfuse-worker:
    image: langfuse/langfuse-worker:3
    depends_on:
      postgres:
        condition: service_healthy
      clickhouse:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      DATABASE_URL: postgresql://langfuse:langfuse@postgres:5432/langfuse
      CLICKHOUSE_URL: http://clickhouse:8123
      CLICKHOUSE_USER: clickhouse
      CLICKHOUSE_PASSWORD: clickhouse
      REDIS_HOST: redis
      REDIS_PORT: 6379
      SALT: ${LANGFUSE_SALT:?LANGFUSE_SALT must be set; generate with: openssl rand -base64 32}
      ENCRYPTION_KEY: ${LANGFUSE_ENCRYPTION_KEY:?LANGFUSE_ENCRYPTION_KEY must be set; generate with: openssl rand -hex 32}
    networks:
      - langfuse-net

  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: langfuse
      POSTGRES_PASSWORD: langfuse
      POSTGRES_DB: langfuse
    volumes:
      - langfuse_pg_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U langfuse -d langfuse"]
      interval: 5s
      timeout: 3s
      retries: 10
    networks:
      - langfuse-net

  clickhouse:
    image: clickhouse/clickhouse-server:24-alpine
    environment:
      CLICKHOUSE_USER: clickhouse
      CLICKHOUSE_PASSWORD: clickhouse
      CLICKHOUSE_DB: default
    volumes:
      - langfuse_ch_data:/var/lib/clickhouse
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8123/ping"]
      interval: 5s
      timeout: 3s
      retries: 10
    networks:
      - langfuse-net

  redis:
    image: redis:7-alpine
    command: ["redis-server", "--save", "60", "1"]
    volumes:
      - langfuse_redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 10
    networks:
      - langfuse-net

networks:
  langfuse-net:
    driver: bridge

volumes:
  langfuse_pg_data:
  langfuse_ch_data:
  langfuse_redis_data:
