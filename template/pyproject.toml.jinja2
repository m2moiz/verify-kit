[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
# project_name (human-readable): {{ project_name }}
name = "{{ project_slug }}"
version = "0.1.0"
requires-python = ">=3.13"
description = "{{ project_description }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
dependencies = [
    "pydantic>=2",
    "typer>=0.12",
    "rich>=13",
    "pyyaml>=6",
    "structlog>=25",
    "httpx>=0.27",
    "opentelemetry-api==1.41.1",
    "opentelemetry-sdk==1.41.1",
    "opentelemetry-exporter-otlp-proto-grpc==1.41.1",
    # MCP server dependencies. fastmcp pulls `mcp` + `starlette`; we declare
    # them explicitly so the bearer-auth middleware import and
    # ToolAnnotations import are always satisfiable.
    "fastmcp>=3.3,<4",  # pydantic-ai 1.100 transitively requires fastmcp>=3.3 via pydantic-ai-slim[fastmcp]; validate against 3.x APIs (bearer-auth + ToolAnnotations import paths may have moved)
    "mcp>=1.0",
    "starlette>=0.37",
    "uvicorn>=0.30",
{% if has_backend %}
    # FastAPI backend add-on
    "fastapi[standard]>=0.115",
    "pydantic-settings>=2.5",
    # Runtime type-checking hook installed in app/__init__.py (prod=O0 no-op).
    # A runtime dep, not a dev tool: app imports it unconditionally at boot.
    "beartype>=0.22.9",
    "asgi-correlation-id>=4.3",
    "sse-starlette>=2.1",
    "secure>=1.0",
    "pyinstrument>=4.7",
    "anyio>=4.4",
    "asgi-lifespan>=2.1",
    "polyfactory>=2.16",
    "dirty-equals>=0.8",
    # OTel contrib instrumentation — pinned to 0.62b1 to match otel-sdk==1.41.1
    # (which requires semantic-conventions==0.62b1; 0.62b0 requires 0.62b0 -> conflict).
    "opentelemetry-instrumentation-fastapi==0.62b1",
{% endif %}
{% if has_backend and has_db %}
    # Async DB stack
    "sqlalchemy[asyncio]>=2.0",
    "asyncpg>=0.29",
    "alembic>=1.13",
    "opentelemetry-instrumentation-sqlalchemy>=0.62b1,<0.63",
{% endif %}
{% if has_backend and has_logfire %}
    # Logfire opt-in — auto-traces FastAPI + httpx + LLM SDKs.
    # [fastapi] extra pulls opentelemetry-instrumentation-fastapi which logfire.instrument_fastapi() requires.
    "logfire[fastapi]>=0.50",
{% endif %}
{% if has_backend and has_fastapi_mcp %}
    # FastAPI-MCP opt-in — mounts all routes as MCP tools
    "fastapi-mcp>=0.3",
{% endif %}
{% if has_llm %}
    # LLM add-on runtime deps
    "pydantic-ai-slim[anthropic,openai]>=1.100,<2",  # slim + explicit provider extras avoids the otel-semantic-conventions version conflict the full meta-package introduces via [mistral] (needs 0.60b1,<0.61 while otel-sdk==1.41.1 pins 0.62b1)
    "instructor>=1.15,<2",
    "litellm>=1.85,<2",
    "tokencost>=0.1.26",
    "autoevals>=0.2,<0.3",
    "opentelemetry-instrumentation-httpx>=0.62b1,<0.63",  # must match otel-sdk==1.41.1 -> semantic-conventions==0.62b1
    "traceloop-sdk>=0.60,<1",
    "claude-agent-sdk>=0.2.83",
    "langfuse>=4.6,<5",
{% endif %}
]

[dependency-groups]
# PEP 735 dev group. `uv run`, `uv sync`, and `uv run --group dev` all
# include this automatically, so harness subprocess calls to `pytest`,
# `ruff`, `hypothesis`, etc. resolve without `--extra dev`.
# Single source of truth: replaces the deprecated [tool.uv].dev-dependencies
# AND the consumer-facing [project.optional-dependencies].dev (which uv run
# does not sync by default — that was the root cause of GAP-10 layer 5).
dev = [
    "pytest>=8",
    "ruff>=0.6",
    "hypothesis>=6.100",
    "jsonschema>=4.23",
    # Static type checking surfaced by the `typecheck.python` check (standard
    # mode). pyright bundles its own Node via nodejs-wheel — no Node dep on a
    # pure-Python scaffold.
    "pyright>=1.1.405",
    # Dependency-hygiene check (`deps.unused`): flags unused/undeclared deps.
    "deptry>=0.23,<1",
{% if has_backend %}
    # Import-boundary contract (`arch.imports`): harness core must not import app.
    "import-linter>=2.3",
    "pytest-asyncio>=0.24",
    "httpx>=0.27",
    "respx>=0.21",
    # schemathesis API fuzz testing. Pinned to 4.x because the justfile recipe
    # uses 4.x-only flags (--max-response-time, which replaced 3.x's
    # --hypothesis-deadline).
    "schemathesis>=4,<5",
{% endif %}
{% if has_backend and has_db %}
    # Testcontainers for DB integration tests
    "testcontainers[postgres]>=4.7",
{% endif %}
{% if has_llm %}
    # LLM add-on dev deps
    "vcrpy>=8.1,<9",
    "pytest-recording>=0.13.4",
{% endif %}
]

[project.scripts]
verify-kit = "harness.cli:app_entry"
{% if has_backend %}
app-cli = "app.cli:main"
{% endif %}
{% if has_web %}
lost-pixel-approve = "harness.web.lostpixel_adapter:main"
{% endif %}

[tool.hatch.build.targets.wheel]
packages = ["harness"{% if has_backend %}, "app"{% endif %}]

[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
# D = docstrings (public API). PGH = ban blanket type:ignore/noqa. ASYNC = async correctness.
# S = bandit security (subprocess/bind/etc.; legitimate harness calls carry a justified noqa).
# SIM = control-flow simplification. C90 = mccabe complexity. T20 = no stray print().
# RET deliberately NOT enabled (pure style; fights the explicit `result = ...; return result` pattern).
select = ["E", "F", "I", "UP", "B", "D", "ASYNC", "PGH", "S", "SIM", "C90", "T20"]
# B008: FastAPI Depends/Query and Typer Option/Argument require call-in-default by design.
# S607: the harness invokes dev tools (uv/just/ruff/pnpm/docker/git) by PATH name via mise —
# a uniform, intentional pattern; S603 (untrusted-input subprocess) stays enforced per-call.
extend-ignore = ["B008", "S607"]

[tool.ruff.lint.pydocstyle]
# Google convention auto-disables the conflicting D203/D211 and D212/D213 pairs.
convention = "google"

[tool.ruff.lint.mccabe]
# Default ceiling of 10; the harness's own orchestrators (verify/load_config/
# register_tools/...) carry an explicit `# noqa: C901`. Consumer code is held to 10.
max-complexity = 10

[tool.ruff.lint.per-file-ignores]
# Test files: blind-exception asserts (S101), intentional name-bindings, long
# parametrize lines, subprocess (S) and docstring-presence are idiomatic in tests.
"tests/*" = ["B017", "F841", "E501", "E402", "D", "S"]
{% if has_db %}
# Alembic auto-generated migrations and the env.py bootstrap have their own
# conventions (sys.path manipulation before imports; long revision strings).
"alembic/env.py" = ["E402", "D"]
"alembic/versions/*" = ["E501", "D"]
{% endif %}
# CLI help strings, embedded SQL, and MCP tool docstrings are intentionally
# long for readability at the call site.
"harness/cli.py" = ["E501"]
"harness/cache.py" = ["E501"]
"harness/mcp/tools.py" = ["E501"]
# Standalone runner/adapter scripts write progress to stdout by design.
"harness/checks/backend_inprocess_fuzz.py" = ["T201"]
"harness/web/lostpixel_adapter.py" = ["T201"]
# Files that compose imports across conditional template blocks: the rendered
# output can present multiple separate import blocks that ruff would otherwise
# want to merge. Re-sorting across the conditional boundary would change file
# semantics in the opposite polarity from the one currently rendered.
"app/api.py" = ["I001"]
"harness/checks/__init__.py" = ["I001"]

[tool.pyright]
# Surfaced by the `typecheck.python` check (standard mode). Scope to the
# project's own code; the .venv, tests, and generated dirs are excluded by
# default. Keep this aligned with the check's targets.
include = ["harness"{% if has_backend %}, "app"{% endif %}]
typeCheckingMode = "{{ 'strict' if strict_mode else 'standard' }}"
pythonVersion = "3.13"
venvPath = "."
venv = ".venv"

# ── deptry (deps.unused check) ────────────────────────────────────────────────
# deptry auto-treats [dependency-groups] entries as DEV dependencies, so test
# tools (pytest/ruff/pyright/...) are never flagged as unused — no config needed
# for those. This template is multi-variant, though: a regular dependency used
# only at runtime / via a lazy import can look "unused" on a minimal render. Such
# deps are allow-listed per rule below so a base scaffold stays green.
[tool.deptry]
# The `deps.unused` check's contract is undeclared (DEP001) + unused (DEP002).
# DEP003 (imported-but-transitive, e.g. click via typer) and DEP004 (misplaced
# dev dependency, e.g. a test-only lib declared as a runtime dep) are deptry's
# stricter rules and out of this check's scope. Tests + migration dirs are scanned
# (NOT excluded) so test-only and migration-only imports count as "used".
ignore = ["DEP003", "DEP004"]

[tool.deptry.per_rule_ignores]
# DEP002 = declared-but-not-statically-imported. This is a TEMPLATE: it
# intentionally ships add-on dependencies for the consumer to build on, plus
# runtime/plugin deps loaded by NAME (a DB driver via the connection URL, litellm
# callbacks) that never appear as a static `import`. deptry's "every regular dep
# must be imported in source" model does not fit a scaffold, so these are
# allow-listed per add-on. A dep NOT on this list that becomes unused still reds
# the check, and DEP001 (a genuinely missing import) is always enforced.
DEP002 = [
{% if has_backend %}
    "anyio",         # async runtime, used transitively by FastAPI/Starlette
    "polyfactory",   # pydantic test-data factories (shipped for the consumer; used in backend tests)
    "dirty-equals",  # expressive test assertions (used in backend tests)
{% endif %}
{% if has_backend and has_db %}
    "asyncpg",       # async DB driver — loaded via the connection URL, not imported
{% endif %}
{% if has_llm %}
    "pydantic-ai-slim",  # typed LLM agent lib — shipped for the consumer; demonstrated in tests
    "instructor",        # structured-output lib — shipped for the consumer; demonstrated in tests
    "tokencost",         # token-cost accounting — used via litellm at runtime
    "autoevals",         # offline LLM eval scorers — used by the eval tests
    "langfuse",          # LLM observability — loaded via litellm callbacks by name
{% endif %}
]
{% if has_backend %}

# ── import-linter (arch.imports check) ────────────────────────────────────────
# One contract: harness core must not import the consumer's app/ package. The
# fuzz harness legitimately imports app at runtime to exercise the live ASGI app
# — that edge is the sole whitelisted exception.
[tool.importlinter]
root_packages = ["harness", "app"]

[[tool.importlinter.contracts]]
name = "harness core must not import app"
type = "forbidden"
source_modules = ["harness"]
forbidden_modules = ["app"]
ignore_imports = [
    "harness.checks.backend_inprocess_fuzz -> app.main",
    "harness.checks.backend_inprocess_fuzz -> app.auth",
]
{% endif %}
