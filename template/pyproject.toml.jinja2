[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
# project_name (human-readable): {{ project_name }}
name = "{{ project_slug }}"
version = "0.1.0"
requires-python = ">=3.13"
description = "{{ project_description }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
dependencies = [
    "pydantic>=2",
    "typer>=0.12",
    "rich>=13",
    "pyyaml>=6",
    "structlog>=25",
    "httpx>=0.27",
    "opentelemetry-api==1.41.1",
    "opentelemetry-sdk==1.41.1",
    "opentelemetry-exporter-otlp-proto-grpc==1.41.1",
    # MCP server (Plan 03-01). fastmcp pulls `mcp` + `starlette`; we declare
    # them explicitly so the bearer-auth middleware import (Plan 03-01 T03)
    # and ToolAnnotations import (Plan 03-01 T04) are always satisfiable.
    "fastmcp>=2.0,<3.0",
    "mcp>=1.0",
    "starlette>=0.37",
    "uvicorn>=0.30",
]

[project.optional-dependencies]
dev = [
    "pytest>=8",
    "ruff>=0.6",
    "hypothesis>=6.100",
    "jsonschema>=4.23",
]

[project.scripts]
verify-kit = "harness.cli:app_entry"

[tool.hatch.build.targets.wheel]
packages = ["harness"]

[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]
