[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
# project_name (human-readable): {{ project_name }}
name = "{{ project_slug }}"
version = "0.1.0"
requires-python = ">=3.13"
description = "{{ project_description }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
dependencies = [
    "pydantic>=2",
    "typer>=0.12",
    "rich>=13",
    "pyyaml>=6",
    "structlog>=25",
    "httpx>=0.27",
    "opentelemetry-api==1.41.1",
    "opentelemetry-sdk==1.41.1",
    "opentelemetry-exporter-otlp-proto-grpc==1.41.1",
    # MCP server (Plan 03-01). fastmcp pulls `mcp` + `starlette`; we declare
    # them explicitly so the bearer-auth middleware import (Plan 03-01 T03)
    # and ToolAnnotations import (Plan 03-01 T04) are always satisfiable.
    "fastmcp>=2.0,<3.0",
    "mcp>=1.0",
    "starlette>=0.37",
    "uvicorn>=0.30",
{% if has_backend %}
    # FastAPI backend add-on (Plan 04-02)
    "fastapi[standard]>=0.115",
    "pydantic-settings>=2.5",
    "asgi-correlation-id>=4.3",
    "sse-starlette>=2.1",
    "secure>=1.0",
    "pyinstrument>=4.7",
    "anyio>=4.4",
    "asgi-lifespan>=2.1",
    "polyfactory>=2.16",
    "dirty-equals>=0.8",
{% endif %}
{% if has_backend and has_db %}
    # Async DB stack (Plan 04-03)
    "sqlalchemy[asyncio]>=2.0",
    "asyncpg>=0.29",
    "alembic>=1.13",
{% endif %}
{% if has_backend and has_logfire %}
    # Logfire opt-in (Plan 04-06) — auto-traces FastAPI + httpx + LLM SDKs
    "logfire>=0.50",
{% endif %}
{% if has_backend and has_fastapi_mcp %}
    # FastAPI-MCP opt-in (Plan 04-06) — mounts all routes as MCP tools
    "fastapi-mcp>=0.3",
{% endif %}
]

[project.optional-dependencies]
dev = [
    "pytest>=8",
    "ruff>=0.6",
    "hypothesis>=6.100",
    "jsonschema>=4.23",
{% if has_backend %}
    "pytest-asyncio>=0.24",
    "httpx>=0.27",
    "respx>=0.21",
{% endif %}
{% if has_backend and has_db %}
    # Testcontainers for DB integration tests (Plan 04-03)
    "testcontainers[postgres]>=4.7",
{% endif %}
]

[project.scripts]
verify-kit = "harness.cli:app_entry"
{% if has_backend %}
app-cli = "app.cli:main"
{% endif %}

[tool.hatch.build.targets.wheel]
packages = ["harness"{% if has_backend %}, "app"{% endif %}]

[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]
