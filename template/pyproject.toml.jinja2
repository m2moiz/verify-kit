[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
# project_name (human-readable): {{ project_name }}
name = "{{ project_slug }}"
version = "0.1.0"
requires-python = ">=3.13"
description = "{{ project_description }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
dependencies = [
    "pydantic>=2",
    "typer>=0.12",
    "rich>=13",
    "pyyaml>=6",
]

[project.optional-dependencies]
dev = ["pytest>=8", "ruff>=0.6"]

[project.scripts]
verify-kit = "harness.cli:app"

[tool.hatch.build.targets.wheel]
packages = ["harness"]

[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]
