/**
 * harness/web/api — minimal fetch wrapper.
 * BASE_URL strategy per D-W05:
 *   - has_backend=true: prefix relative `/api/*` paths (proxied by Vite dev → :8000; same-origin in prod)
 *   - has_backend=false: read VITE_API_BASE_URL from env (consumer wires their own backend)
 */
import { API_BASE_URL } from "@/config";

export async function api<T = unknown>(path: string, init?: RequestInit): Promise<T> {
  const url = path.startsWith("http") ? path : `${API_BASE_URL}${path}`;
  const res = await fetch(url, init);
  if (!res.ok) throw new Error(`api ${res.status}: ${res.statusText}`);
  return res.json() as Promise<T>;
}

export const BASE_URL = API_BASE_URL;
