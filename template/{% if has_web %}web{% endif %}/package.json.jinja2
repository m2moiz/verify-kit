{
  "name": "{{ project_name | lower | replace(' ', '-') }}-web",
  "version": "0.1.0",
  "description": "{{ project_description }} (web frontend)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:axe": "playwright test axe.spec.ts",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:a11y": "playwright test axe.spec.ts",
    "lighthouse": "lhci autorun",
    "visual": "lost-pixel"
  },
  "dependencies": {
    "@opentelemetry/context-zone": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-fetch": "^0.218.0",
    "@opentelemetry/sdk-trace-web": "^2.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "lost-pixel": "^3.22.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^3.2.0",
    "happy-dom": "^17.0.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.2.0",
    "typescript": "~5.7.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  }
}
