# Fast-only pre-commit hooks. Anything >3s belongs in CI (DEV-02).
# To skip a single hook for one commit: SKIP=<hook-id> git commit
# To skip gitleaks on large staged diffs: SKIP=gitleaks git commit
# Full-repo scans (type-check, test runner, linters) run in .github/workflows/ci.yml only.
repos:
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v5.0.0
    hooks:
      - id: end-of-file-fixer
      - id: trailing-whitespace
      - id: check-yaml
      - id: check-toml
      - id: check-merge-conflict
      - id: check-added-large-files
        args: [--maxkb=500]

  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.15.15
    hooks:
      - id: ruff
        args: [--fix]
      - id: ruff-format

  {% if has_backend or has_llm %}
  # Pyright type-checks staged Python files only (fast path).
  # Full-repo type-check runs in .github/workflows/ci.yml via `just verify`.
  # Skip for a single commit: SKIP=pyright git commit
  - repo: https://github.com/RobertCraigie/pyright-python
    rev: v1.1.409
    hooks:
      - id: pyright
        # Default behavior already targets staged files. We pin the
        # working dir so pyright resolves the project's pyrightconfig.json
        # / pyproject.toml correctly.
        pass_filenames: true
        types_or: [python, pyi]
  {% endif %}

  # markdownlint catches dead links, broken tables, and inconsistent
  # heading hierarchy in .md files at commit time. Fast (<1s on typical
  # diffs). Full-repo scan is part of CI.
  - repo: https://github.com/igorshubovych/markdownlint-cli
    rev: v0.42.0
    hooks:
      - id: markdownlint
        # Keep the rule set permissive by default — the template's own
        # docs use line-length variations and inline HTML deliberately.
        # Consumers can tighten by adding a .markdownlint.json at repo root.
        args: [--disable, MD013, MD033, MD041, "--"]

  {% if has_llm %}
  # Biome pre-commit lands when LLM add-on brings JSON/eval config files.
  # When backend add-on lands in Phase 4, it injects its own block here.
  - repo: https://github.com/biomejs/pre-commit
    rev: v0.6.1
    hooks:
      - id: biome-check
        files: \.(js|jsx|ts|tsx|json)$
  {% endif %}

  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.30.1
    hooks:
      - id: gitleaks
        # Fast path: gitleaks runs incrementally on staged files by default,
        # honoring the DEV-02 <3s budget on normal-sized diffs. Users with
        # very large staged changes can run `SKIP=gitleaks git commit` to
        # bypass for one commit, or move gitleaks to manual stage:
        #   stages: [manual]  (then invoke via `pre-commit run --hook-stage manual gitleaks`)
        # CI re-runs the full-repo scan in .github/workflows/ci.yml.
