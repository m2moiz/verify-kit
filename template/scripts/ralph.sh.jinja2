#!/usr/bin/env bash
# Thin wrapper around `verify-kit ralph run`. Reads --max-iterations and
# --cost-cap-usd from CLI args (or RALPH_MAX_ITERS / RALPH_COST_CAP_USD env),
# passes the rest as the Ralph prompt.
set -euo pipefail
MAX_ITERS="${RALPH_MAX_ITERS:-5}"
COST_CAP="${RALPH_COST_CAP_USD:-1.0}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --max-iterations) MAX_ITERS="$2"; shift 2 ;;
    --max-iterations=*) MAX_ITERS="${1#*=}"; shift ;;
    --cost-cap-usd) COST_CAP="$2"; shift 2 ;;
    --cost-cap-usd=*) COST_CAP="${1#*=}"; shift ;;
    --) shift; break ;;
    *) break ;;
  esac
done
# Supports BOTH `--flag value` and `--flag=value` forms.
exec verify-kit ralph run --max-iterations="$MAX_ITERS" --cost-cap-usd="$COST_CAP" "$@"
