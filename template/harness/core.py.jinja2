"""harness.core — thin facade over harness.runner.run_phase.

Phase-2 restructure (Plan 02-06, Task 1):

- The Phase-1 _check_* implementations have been migrated into
  ``harness.checks.*`` and re-registered through ``@register`` (Plan 02-04).
- ``harness.core`` is now a **thin facade**: it does tier/check-id filtering,
  wires up the cache + config, calls ``run_phase``, and packages results into
  a ``VerifyReport``. No check business logic lives here.
- Public API signatures ``verify(...)`` and ``list_checks()`` are preserved
  for Phase-1 callers; only the implementation moved.

**cwd contract (convergence-HIGH guard):** when a caller passes an explicit
``cwd=tmp_path``, this module MUST resolve config under that path —
``load_config(cwd / "pyproject.toml")`` — not the process CWD. Otherwise a
caller invoking ``core.verify(cwd=tmp_path)`` from a different process CWD
silently picks up the wrong config file.

**Cache-eviction order (convergence-HIGH guard):** ``cache.evict_if_needed``
runs **before** ``return``. Writing ``return report; cache.evict_if_needed(...)``
makes the eviction call dead code and the cache cap is never enforced.
"""
from __future__ import annotations

import time
from pathlib import Path

import harness.checks  # noqa: F401 — trigger @register side-effects (discovery)
from harness.cache import CacheCorruptError, CacheStore
from harness.config import HarnessConfig, load_config
from harness.didyoumean import suggest
from harness.logging import log
from harness.models import VerifyReport
from harness.registry import list_checks as registry_list_checks
from harness.runner import run_phase


def list_checks() -> list[str]:
    """Return the registered check ids as strings (Phase-1 signature preserved)."""
    return [s.check_id for s in registry_list_checks()]


def verify(
    check_ids: list[str] | None = None,
    fix: bool = False,
    tier: str = "standard",
    no_cache: bool = False,
    cwd: Path = Path("."),
    config: HarnessConfig | None = None,
) -> VerifyReport:
    """Run the requested checks (or all of them) and return a VerifyReport.

    Args:
        check_ids: Specific check IDs to run. ``None`` means apply tier filter
            to the whole registry. Unknown ids raise ``ValueError`` with a
            did-you-mean suggestion appended.
        fix: Phase-2 metadata-only flag — see scope_fence in 02-CONTEXT. Logged
            and ignored; broader fixer wiring lands in later phases.
        tier: ``"quick"``, ``"standard"`` (default), or ``"full"``. Unknown
            value raises ``ValueError``.
        no_cache: When True, bypass the SQLite cache for this run.
        cwd: Project root the checks operate against. Used for cache root,
            check fn cwd argument, **and** config path resolution.
        config: Optional pre-loaded ``HarnessConfig``. When ``None``, loaded
            from ``cwd / "pyproject.toml"`` (cwd contract).

    Returns:
        A fully-populated ``VerifyReport`` (including ``summary``).
    """
    # ── config (cwd contract — convergence-HIGH guard) ────────────────────────
    # MUST be `cwd / "pyproject.toml"`, NOT the no-arg `load_config()` default
    # which resolves under the process CWD. The unit test
    # test_verify_cwd_contract_reads_argument_pyproject monkey-patches a process
    # CWD that differs from `cwd` and asserts we read from `cwd`.
    if config is None:
        config = load_config(cwd / "pyproject.toml")

    if fix:
        # Phase-2 scope_fence: --fix is metadata-only here; broader fixer
        # wiring lands in later phases (per 02-CONTEXT).
        log.warning(
            "verify.fix_noop_phase2",
            note="--fix is metadata-only in Phase 2; broader fixer wiring lands in later phases",
        )

    # ── resolve specs ─────────────────────────────────────────────────────────
    all_specs = registry_list_checks()

    if tier == "quick":
        filtered = [s for s in all_specs if s.tier == "quick"]
    elif tier == "standard":
        filtered = [s for s in all_specs if s.tier in ("quick", "standard")]
    elif tier == "full":
        filtered = list(all_specs)
    else:
        raise ValueError(
            f"Unknown tier {tier!r}. did you mean: one of 'quick', 'standard', 'full'?"
        )

    if check_ids is not None:
        known_ids = [s.check_id for s in all_specs]
        by_id = {s.check_id: s for s in all_specs}
        selected: list = []
        for cid in check_ids:
            spec = by_id.get(cid)
            if spec is None:
                matches = suggest(cid, known_ids)
                hint = (
                    ", ".join(matches) if matches else "(no close match)"
                )
                raise ValueError(
                    f"Unknown check id {cid!r}. did you mean: {hint}?"
                )
            selected.append(spec)
        filtered = selected

    # Defense-in-depth: also filter disabled via config (runner re-checks too).
    disabled = set(config.checks.disabled or [])
    filtered = [s for s in filtered if s.check_id not in disabled]

    # ── cache ────────────────────────────────────────────────────────────────
    cache: CacheStore | None
    if no_cache or not config.cache.enabled:
        cache = None
    else:
        try:
            cache = CacheStore((cwd / ".verify" / "cache.db"))
        except CacheCorruptError:
            # Surface to the CLI which maps to EXIT_CACHE_CORRUPT=10.
            raise

    # ── run ──────────────────────────────────────────────────────────────────
    start = time.monotonic()
    results = run_phase(filtered, cwd=cwd, cache=cache, config=config)
    total_ms = int((time.monotonic() - start) * 1000)

    report = VerifyReport.from_checks(results, total_duration_ms=total_ms)

    # ── eviction (convergence-HIGH guard — MUST be before `return`) ──────────
    # Placing this AFTER `return report` would make the call dead code and the
    # cache cap would never be enforced. The unit test
    # test_verify_evicts_before_return spies CacheStore.evict_if_needed and
    # asserts call_count==1 at the moment verify() returns.
    if cache is not None:
        cache.evict_if_needed(config.cache.max_size_mb * 1_000_000)

    return report


__all__ = ["verify", "list_checks"]
