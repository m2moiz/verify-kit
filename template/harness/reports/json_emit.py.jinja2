"""harness.reports.json_emit — Decision 1.1 inline-error JSON envelope.

The wire shape mirrors VerifyReport.model_dump(exclude_none=True): each
CheckResult embeds its ErrorEnvelope under `error` (NOT a parallel array).
Optional ErrorEnvelope fields collapse out via `exclude_none`.
"""
from __future__ import annotations

import json
from typing import IO

from harness.models import VerifyReport


def emit(report: VerifyReport, stream: IO[str]) -> None:
    """Write `report` to `stream` as pretty-printed JSON (Decision 1.1 shape)."""
    payload = report.model_dump(exclude_none=True, mode="json")
    json.dump(payload, stream, indent=2)
    stream.write("\n")


__all__ = ["emit"]
