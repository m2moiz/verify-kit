"""harness.checks.backend — backend slice (schemathesis + smoke + integration).

Registered with the harness check registry when has_backend=true. The check
exits 0 (status="pass") when all sub-steps pass, status="fail" on any failure.
NEVER reads Path.cwd() — every subprocess takes explicit cwd from the harness
runner's CheckSpec.fn(cwd=cwd) call contract.
"""

from __future__ import annotations

import subprocess
import time
from pathlib import Path

from harness.models import CheckResult, ErrorEnvelope
from harness.proc import run as proc_run
from harness.registry import register

# Adversarial schemathesis checks that encode an auth/validation policy the
# scaffold does NOT adopt. verify-kit ships an intentionally-minimal OPTIONAL
# auth scaffold (Phase 6 / 06-02), not a lock-everything-down model — endpoints
# are open by design in the dev scaffold. schemathesis 4.x's `ignored_auth`,
# `negative_data_rejection`, `missing_required_header`, and
# `positive_data_acceptance` checks assert policies the scaffold intentionally
# leaves to the consumer, so they produce false failures here.
#
# CRITICAL — live↔in-process consistency (verify-kit-gm3): this list MUST match
# the `excluded_check_names` in harness/checks/backend_inprocess_fuzz.py. The
# two fuzz paths (live over-network when the app is up; in-process via
# ASGITransport otherwise) must agree on which checks run — otherwise the same
# scaffold passes the in-process path and fails the live path (the live-full CI
# job), which is exactly the gap this branch exists to close. If you change one
# list, change the other.
_EXCLUDED_SCHEMATHESIS_CHECKS = (
    "negative_data_rejection",
    "positive_data_acceptance",
    "missing_required_header",
    "ignored_auth",
)


def _docker_reachable(timeout_s: float = 3.0) -> bool:
    """Probe whether the Docker daemon answers within `timeout_s`.

    Backend integration tests use Testcontainers-Postgres which requires a
    reachable Docker daemon. When Docker is not running, Testcontainers hangs
    on container creation rather than failing fast — which cascades into the
    harness's 600s pytest timeout. Probing `docker info` upfront lets us skip
    cleanly with a clear hint, matching the offline-first / graceful-degradation
    pattern the rest of the harness uses (biome skip when missing, etc.).
    """
    import shutil

    if shutil.which("docker") is None:
        return False
    try:
        r = subprocess.run(
            ["docker", "info", "--format", "{% raw %}{{.ServerVersion}}{% endraw %}"],
            capture_output=True,
            text=True,
            timeout=timeout_s,
        )
        return r.returncode == 0 and r.stdout.strip() != ""
    except (subprocess.TimeoutExpired, OSError):
        return False


@register(
    "backend",
    tier="standard",
    category="backend",
    description=(
        "Runs pytest backend tests, then schemathesis fuzz against the live "
        "OpenAPI (over-network when app reachable on :8000, in-process via "
        "ASGITransport otherwise), and smoke-tests /healthz."
    ),
    # Cache key inputs: editing the app, its tests, or its deps must invalidate
    # this check's cached result. Without these, a route/lifespan change leaves a
    # stale pass/fail in the cache (verify-kit-b4z).
    inputs=["app/**", "tests/backend/**", "pyproject.toml"],
    fixable=False,
    tool="uv",
)
def run(cwd: Path) -> CheckResult:
    """Execute the backend slice. cwd is the scaffold root — passed by the harness runner."""
    start = time.monotonic()

    # Preflight: backend integration tests need Docker for Testcontainers-Postgres.
    # Skip with a clear hint if the daemon is unreachable, instead of timing
    # out the umbrella `just verify` after 600s on container-startup hang.
    if not _docker_reachable():
        return CheckResult(
            check_id="backend",
            status="skip",
            message=(
                "Docker daemon not reachable; backend integration tests require "
                "Testcontainers-Postgres. Start Docker Desktop (or your daemon) "
                "and re-run, or use `just verify-backend` which brings the stack "
                "up explicitly via docker-compose."
            ),
            duration_ms=int((time.monotonic() - start) * 1000),
        )

    # Step 1: pytest unit + integration (Testcontainers handles its own DB).
    # 180s timeout: enough for cold Testcontainers Postgres startup + 24 tests,
    # short enough to surface real hangs in 3 minutes instead of 10. The
    # prior 600s default hid the verify-kit-8q7 L6 fastapi-mcp SSE hang for
    # 10 minutes per CI cycle.
    r = proc_run(
        ["uv", "run", "pytest", "tests/backend/", "-q", "--tb=short"],
        cwd=cwd,
        timeout=180,
    )
    if r.returncode != 0:
        return CheckResult(
            check_id="backend",
            status="fail",
            message=f"backend pytest failed:\n{r.stdout}\n{r.stderr}",
            duration_ms=int((time.monotonic() - start) * 1000),
            error=ErrorEnvelope(
                code="backend.pytest-fail",
                message=f"backend pytest failed:\n{r.stdout}\n{r.stderr}",
                fix_command=f"cd {cwd} && uv run pytest tests/backend/ -v",
                docs_url="https://github.com/m2moiz/verify-kit#backend-slice",
            ),
        )

    # Step 2: schemathesis schema-fuzz. An earlier implementation SKIPPED
    # schemathesis entirely when the live app was unreachable,
    # so `just verify` (which does NOT start docker) never ran the fuzz — API-18
    # was unproven. The umbrella check now ALWAYS runs schemathesis. If the live
    # app is reachable, we fuzz the LIVE OpenAPI (over-network — the canonical
    # path). If not, we fall back to the IN-PROCESS path: invoke the
    # harness.checks.backend_inprocess_fuzz helper (T07's file) so requests
    # never leave the process.
    try:
        import httpx

        httpx.get("http://localhost:8000/healthz", timeout=2.0)
        app_running = True
    except Exception:
        app_running = False

    if app_running:
        # Over-network path: schemathesis against the LIVE running app.
        # 300s is a legitimate override — schemathesis with max-examples=20
        # across the full route surface can genuinely take 2-4 minutes.
        #
        # Run all checks EXCEPT the adversarial auth/validation ones the scaffold
        # does not adopt (see _EXCLUDED_SCHEMATHESIS_CHECKS). schemathesis 4.x
        # exposes `--exclude-checks <comma-list>`; mirroring the in-process
        # path's exclusions keeps the two fuzz paths consistent (verify-kit-gm3).
        r2 = proc_run(
            [
                "uv",
                "run",
                "schemathesis",
                "run",
                "http://localhost:8000/openapi.json",
                "--checks",
                "all",
                "--exclude-checks",
                ",".join(_EXCLUDED_SCHEMATHESIS_CHECKS),
                "--max-examples",
                "20",
                "--max-response-time",
                "2",
            ],
            cwd=cwd,
            timeout=300,
        )
        if r2.returncode != 0:
            return CheckResult(
                check_id="backend",
                status="fail",
                message=f"schemathesis (live) found schema issues:\n{r2.stdout}\n{r2.stderr}",
                duration_ms=int((time.monotonic() - start) * 1000),
                error=ErrorEnvelope(
                    code="backend.schemathesis-live-fail",
                    message=(
                        f"schemathesis (live) found schema issues:\n{r2.stdout}\n{r2.stderr}"
                    ),
                    fix_command=(
                        f"cd {cwd} && uv run schemathesis run "
                        "http://localhost:8000/openapi.json --checks all "
                        f"--exclude-checks {','.join(_EXCLUDED_SCHEMATHESIS_CHECKS)}"
                    ),
                    docs_url="https://schemathesis.readthedocs.io/",
                ),
            )
    else:
        # In-process path: fuzz via ASGITransport using the T07 helper.
        # Calls harness.checks.backend_inprocess_fuzz (the sibling file
        # written by the in-process fuzz module). Using subprocess keeps the heavy
        # hypothesis engine isolated from the harness runner process.
        r2 = proc_run(
            [
                "uv",
                "run",
                "python",
                "-m",
                "harness.checks.backend_inprocess_fuzz",
                "--max-examples",
                "10",
                "--cwd",
                str(cwd),
            ],
            cwd=cwd,
            timeout=300,
        )
        if r2.returncode != 0:
            return CheckResult(
                check_id="backend",
                status="fail",
                message=(
                    f"schemathesis (in-process) found schema issues:\n{r2.stdout}\n{r2.stderr}"
                ),
                duration_ms=int((time.monotonic() - start) * 1000),
                error=ErrorEnvelope(
                    code="backend.schemathesis-inprocess-fail",
                    message=(
                        f"schemathesis (in-process) found schema issues:\n"
                        f"{r2.stdout}\n{r2.stderr}"
                    ),
                    fix_command=(
                        f"cd {cwd} && uv run python -m harness.checks.backend_inprocess_fuzz"
                    ),
                    docs_url="https://schemathesis.readthedocs.io/",
                ),
            )

    return CheckResult(
        check_id="backend",
        status="pass",
        message="backend slice OK",
        duration_ms=int((time.monotonic() - start) * 1000),
    )
