"""harness.checks.web — web add-on verifier registrations.

Seven checks: web.vitest, web.playwright, web.lighthouse, web.axe,
web.lost_pixel, web.otel_trace, web.typecheck.

FROZEN API contract: @register kwargs are `tier, category, description, inputs,
fixable, tool, skip_if_unavailable`. NO `severity=`, NO `tags=`, NO MCP-level
hint kwargs. ErrorEnvelope has NO `fixable` field — fixability lives on the
@register decorator (per-check) and is encoded in the envelope `code` suffix
(per-finding). See 07-RESEARCH.md §Producer API Surface (Frozen).

Verified signatures (2026-05-27):
  @register (template/harness/registry.py.jinja2:20):
    def register(check_id, *, tier, category, description, inputs,
                 fixable, tool, skip_if_unavailable) -> Callable
  CheckStatus = Literal["pass", "fail", "skip"]  — NO "warning" variant
  CheckResult.error: ErrorEnvelope | None  — single envelope; multi-finding
    detail is in per-check SARIF files (e.g. .verify/web/axe.sarif)
  proc.run (template/harness/proc.py.jinja2:32):
    def run(args, *, cwd, capture_output, text, timeout, check, env)
    DEFAULT_TIMEOUT_S = 60.0

Subprocess discipline (every web check):
  - cwd=cwd / "web"  (pnpm exec resolves node_modules/.bin against CWD)
  - env=clean_env()  (strips VIRTUAL_ENV, PYTHONPATH, NODE_*, PNPM_HOME, NVM_*)
  Per 07-RESEARCH.md §proc.run discipline + threat T-07-24.
"""
from __future__ import annotations

import json
import os
import shutil
import subprocess
import time
from pathlib import Path

from harness.models import CheckResult, CheckStatus, ErrorEnvelope
from harness.proc import run as proc_run
from harness.registry import register
from harness.web._env import clean_env
from harness.web.axe_adapter import parse_axe_output, write_sarif
from harness.web.lighthouse_adapter import parse_lighthouse_output
from harness.web.lostpixel_adapter import parse_lostpixel_output

# Docker image pinned for Lost Pixel (D-W02 — prevents cross-platform font drift)
_DOCKER_IMAGE = "mcr.microsoft.com/playwright:v1.60.0-jammy"

# Source globs whose contents determine the production build. Used both as the
# @register cache `inputs` for the preview-serving checks (web.lighthouse,
# web.lost_pixel) AND as the fingerprint for the build-once guard below.
# verify-kit-b49: a stale web/dist must NOT false-green a real source change.
# The cache key (run_id) must invalidate when web/src changes; the check itself
# must rebuild web/dist before serving so the comparison/audit is never stale.
_WEB_BUILD_INPUTS = [
    "web/src/**",
    "web/index.html",
    "web/vite.config.ts",
    "web/tsconfig.json",
    "web/package.json",
]

# Build-once guard (process-scoped). When both web.lighthouse and web.lost_pixel
# run in a single `just verify` process, they would each rebuild web/dist from
# the same sources — wasteful. We record the fingerprint of the last SUCCESSFUL
# build keyed by source-hash so the second check skips the redundant rebuild.
_LAST_WEB_BUILD_FINGERPRINT: str | None = None


def _ensure_web_build(cwd: Path) -> tuple[bool, str]:
    """Build web/dist from source before a preview-serving check runs.

    verify-kit-b49 (false-green class): web.lighthouse and web.lost_pixel both
    serve `vite preview` (directly, or via LHCI startServerCommand) against
    web/dist. If `just verify` did not rebuild, they compare/audit a STALE build
    and a real source change goes undetected — the same false-green class as the
    v0.2 visual-regression incident. So we always (re)build here.

    `pnpm` is resolved from PATH (mise-provisioned at the pinned 9.15.0, matching
    web/package.json's packageManager — verify-kit-49l). clean_env() strips
    PNPM_HOME/NODE_*/NVM_* so the scaffold's own pnpm/node is used, never an
    outer leak. Build runs from `cwd` with `--dir web` (not cwd/"web") so a
    relative `cwd` from the runner stays valid.

    Returns ``(ok, output_tail)``: ``ok`` is True on a clean build (returncode 0);
    ``output_tail`` is the last ~800 chars of combined stdout/stderr (the build
    error, surfaced by the caller in an ErrorEnvelope on failure).

    Build-once: when the source fingerprint matches the last successful build in
    THIS process and web/dist already exists, the rebuild is skipped so two
    preview-serving checks in one run do not double-build identical sources.
    """
    global _LAST_WEB_BUILD_FINGERPRINT

    from harness.cache import hash_inputs  # noqa: PLC0415 — avoid import cycle

    # Fingerprint the build inputs (sorted file hashes → deterministic string).
    file_hashes = hash_inputs(_WEB_BUILD_INPUTS, cwd)
    fingerprint = "\n".join(f"{p}={h}" for p, h in sorted(file_hashes.items()))

    dist_dir = cwd / "web" / "dist"
    if (
        _LAST_WEB_BUILD_FINGERPRINT is not None
        and _LAST_WEB_BUILD_FINGERPRINT == fingerprint
        and dist_dir.exists()
    ):
        # Identical sources already built in this process — skip the rebuild.
        return True, ""

    build_result = proc_run(
        ["pnpm", "--dir", "web", "build"],
        cwd=cwd,
        env=clean_env(),
        timeout=300.0,
    )
    combined = ((build_result.stdout or "") + (build_result.stderr or "")).strip()
    output_tail = combined[-800:] if combined else "(no build output captured)"

    if build_result.returncode != 0:
        return False, output_tail

    _LAST_WEB_BUILD_FINGERPRINT = fingerprint
    return True, output_tail


# ── web.vitest ────────────────────────────────────────────────────────────────


@register(
    "web.vitest",
    tier="standard",
    category="test",
    description="Vitest unit + component tests for web/",
    inputs=["web/**/*.ts", "web/**/*.tsx", "web/package.json"],
    fixable=False,
    tool="vitest",
)
def check_web_vitest(cwd: Path) -> CheckResult:
    """Run vitest in the web/ directory.

    Timeout: 120s — enough for cold happy-dom startup + component renders.
    Uses proc_run with cwd=cwd/"web" and clean_env() per subprocess discipline.
    """
    t0 = time.monotonic()
    result = proc_run(
        ["pnpm", "exec", "vitest", "run", "--reporter=default"],
        cwd=cwd / "web",
        env=clean_env(),
        timeout=120.0,
    )
    duration_ms = int((time.monotonic() - t0) * 1000)

    status: CheckStatus = "pass" if result.returncode == 0 else "fail"
    err: ErrorEnvelope | None = None
    if status == "fail":
        err = ErrorEnvelope(
            code="web.vitest.failed",
            message=f"vitest exited {result.returncode}",
            hint="Inspect vitest output above; run `cd web && pnpm exec vitest` to iterate",
            fix_command="cd web && pnpm exec vitest",
            docs_url="https://vitest.dev/guide/",
        )
    return CheckResult(
        check_id="web.vitest",
        status=status,
        duration_ms=duration_ms,
        error=err,
    )


# ── web.playwright ────────────────────────────────────────────────────────────


@register(
    "web.playwright",
    tier="standard",
    category="test",
    description="Playwright E2E smoke for web/",
    inputs=["web/tests/e2e/**", "web/playwright.config.ts"],
    fixable=False,
    tool="playwright",
    skip_if_unavailable=True,  # Chromium download may not be present locally
)
def check_web_playwright(cwd: Path) -> CheckResult:
    """Run Playwright smoke suite against `vite preview`.

    Timeout: 180s — Playwright starts vite preview as webServer per playwright.config.ts;
    allow 3 minutes for cold Chromium startup + test execution.

    The playwright.config.ts.jinja2 (07-05) configures webServer with vite preview
    so the check correctly runs against a production build (not vite dev).
    """
    t0 = time.monotonic()

    # Ensure Chromium is installed (idempotent; cached after first install)
    install_result = proc_run(
        ["pnpm", "exec", "playwright", "install", "--with-deps", "chromium"],
        cwd=cwd / "web",
        env=clean_env(),
        timeout=300.0,
    )
    if install_result.returncode != 0:
        duration_ms = int((time.monotonic() - t0) * 1000)
        return CheckResult(
            check_id="web.playwright",
            status="skip",
            message=(
                "Playwright Chromium install failed — skipping E2E "
                "(run `cd web && pnpm exec playwright install chromium`)"
            ),
            duration_ms=duration_ms,
        )

    result = proc_run(
        ["pnpm", "exec", "playwright", "test"],
        cwd=cwd / "web",
        env={**clean_env(), "CI": "1"},  # CI=1 → single worker
        timeout=180.0,
    )
    duration_ms = int((time.monotonic() - t0) * 1000)

    status: CheckStatus = "pass" if result.returncode == 0 else "fail"
    err: ErrorEnvelope | None = None
    if status == "fail":
        # Surface the reporter tail so the failing spec + assertion are visible
        # without a re-run — the bare exit code is undebuggable in CI. Playwright
        # writes the failure summary to stdout; fall back to stderr.
        diag = (result.stdout or "").strip() or (result.stderr or "").strip()
        diag_tail = diag[-800:] if diag else "(no reporter output captured)"
        err = ErrorEnvelope(
            code="web.playwright.failed",
            message=f"Playwright exited {result.returncode}: {diag_tail}",
            hint="Run `cd web && pnpm exec playwright test --reporter=list` for details",
            fix_command="cd web && pnpm exec playwright test",
            docs_url="https://playwright.dev/docs/running-tests",
        )
    return CheckResult(
        check_id="web.playwright",
        status=status,
        duration_ms=duration_ms,
        error=err,
    )


# ── web.lighthouse ────────────────────────────────────────────────────────────


@register(
    "web.lighthouse",
    tier="slow",
    category="perf",
    description="Lighthouse CI median-of-5 budgets (LCP/CLS/INP)",
    # verify-kit-b49: web/src + build config are inputs so a source change
    # invalidates the cached run_id. Declaring only web/dist would let a cache
    # replay keep a stale run_id when web/dist was not rebuilt (false-green).
    inputs=[*_WEB_BUILD_INPUTS, "web/lighthouserc.json"],
    fixable=False,
    tool="lhci",
    skip_if_unavailable=True,
)
def check_web_lighthouse(cwd: Path) -> CheckResult:
    """Run LHCI autorun and parse budget failures.

    PERF-04 GUARD: HEAD-request the target URL; reject with
    code='lighthouse.target.invalid' if HMR markers are detected
    (i.e. running against vite dev instead of vite preview).

    verify-kit-b49: rebuild web/dist BEFORE LHCI serves `vite preview` against
    it (via lighthouserc.json startServerCommand). Without the rebuild, LHCI
    audits a STALE build and a real regression goes undetected (false-green).

    Timeout: 300s — 5 Lighthouse runs can hit 90s total; LHCI is tagged
    tier="slow" so it is excluded from `just verify` by default.
    """
    import urllib.error
    import urllib.request

    t0 = time.monotonic()
    target_url = "http://localhost:4173/"

    # ── verify-kit-b49: rebuild web/dist before LHCI serves it ────────────────
    build_ok, build_tail = _ensure_web_build(cwd)
    if not build_ok:
        duration_ms = int((time.monotonic() - t0) * 1000)
        return CheckResult(
            check_id="web.lighthouse",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.lighthouse.build.failed",
                message=f"`pnpm --dir web build` failed before Lighthouse run: {build_tail}",
                hint="Fix the build error above; run `cd web && pnpm build` to iterate",
                fix_command="pnpm --dir web build",
                docs_url="https://vitejs.dev/guide/build.html",
            ),
        )

    # PERF-04: precondition — refuse if target looks like vite dev (HMR markers)
    try:
        req = urllib.request.Request(target_url, method="HEAD")
        with urllib.request.urlopen(req, timeout=5) as resp:
            server_hdr = resp.headers.get("Server", "")
            etag_hdr = resp.headers.get("ETag", "")
            if "Vite" in server_hdr or "vite" in etag_hdr.lower():
                duration_ms = int((time.monotonic() - t0) * 1000)
                return CheckResult(
                    check_id="web.lighthouse",
                    status="fail",
                    duration_ms=duration_ms,
                    error=ErrorEnvelope(
                        code="lighthouse.target.invalid",
                        message=(
                            f"Lighthouse target {target_url} appears to be vite dev "
                            "(HMR markers detected in response headers). "
                            "Lighthouse MUST run against `vite preview` (PERF-04)."
                        ),
                        hint="Run `pnpm build && pnpm exec vite preview --port 4173` first",
                        fix_command="cd web && pnpm build && pnpm exec vite preview --port 4173",
                        docs_url="https://web.dev/performance/",
                    ),
                )
    except urllib.error.URLError:
        # Server not running — LHCI will start it via lighthouserc.json startServerCommand
        pass

    result = proc_run(
        ["pnpm", "exec", "lhci", "autorun"],
        cwd=cwd / "web",
        env=clean_env(),
        timeout=300.0,
    )
    duration_ms = int((time.monotonic() - t0) * 1000)

    # LHCI writes manifest.json + lhr-*.report.json under the `outputDir` from
    # lighthouserc.json (`./.verify/web/lighthouse`), resolved RELATIVE TO the
    # subprocess cwd (cwd/"web") — so the actual location is web/.verify/web/
    # lighthouse, NOT the repo-root .verify (verify-kit-ir1 path fix; the check
    # previously read cwd/.verify and never found the report). The lhr JSON is
    # written even on an assertion failure (upload.target=filesystem runs
    # regardless of the assert step's exit code).
    lighthouse_dir = cwd / "web" / ".verify" / "web" / "lighthouse"

    # verify-kit-ir1: a non-zero exit is the EXACT case parse_lighthouse_output
    # was written for (lhci exits 1 on an error-severity assertion breach). Try
    # the rich parser FIRST so the failure names the breaching audit
    # (web.lighthouse.budget.<metric> with actual-vs-budget) instead of a generic
    # `web.lighthouse.run.failed`. Only when the parser is empty/raises AND the
    # exit is non-zero is this a genuine collect failure → generic fallback.
    if result.returncode != 0:
        try:
            named_envelopes = parse_lighthouse_output(lighthouse_dir)
        except Exception:
            named_envelopes = []

        if named_envelopes:
            return CheckResult(
                check_id="web.lighthouse",
                status="fail",
                duration_ms=duration_ms,
                error=named_envelopes[0],  # named breach; full list in LHCI report
            )

        # Genuine collect failure (no parseable lhr) — surface the lhci tail so
        # the bare exit code is not the only diagnostic.
        diag = (result.stderr or "").strip() or (result.stdout or "").strip()
        diag_tail = diag[-800:] if diag else "(no lhci output captured)"
        return CheckResult(
            check_id="web.lighthouse",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.lighthouse.run.failed",
                message=(
                    f"lhci autorun exited {result.returncode} "
                    f"(no parseable report): {diag_tail}"
                ),
                hint=(
                    "Check web/lighthouserc.json assertions and run "
                    "`cd web && pnpm exec lhci autorun`"
                ),
                fix_command="cd web && pnpm exec lhci autorun",
                docs_url="https://github.com/GoogleChrome/lighthouse-ci/blob/main/docs/getting-started.md",
            ),
        )

    # returncode == 0 — still parse budget failures (warn-severity assertions or
    # a defensive re-parse). A clean run yields an empty envelope list → pass.
    try:
        envelopes = parse_lighthouse_output(lighthouse_dir)
    except Exception:
        envelopes = []

    if envelopes:
        return CheckResult(
            check_id="web.lighthouse",
            status="fail",
            duration_ms=duration_ms,
            error=envelopes[0],  # first failure; full list in LHCI report
        )

    return CheckResult(
        check_id="web.lighthouse",
        status="pass",
        duration_ms=duration_ms,
    )


# ── web.axe ───────────────────────────────────────────────────────────────────


@register(
    "web.axe",
    tier="standard",
    category="a11y",
    description="axe-core WCAG 2.1 AA scan against vite preview",
    inputs=["web/dist/**", "web/tests/e2e/axe.spec.ts"],
    fixable=True,
    tool="axe",
)
def check_web_axe(cwd: Path) -> CheckResult:
    """Run axe.spec.ts via Playwright; parse output + emit per-check SARIF.

    The spec writes raw axe JSON to .verify/web/axe.json (both light and
    dark mode violations per A11Y-04). This function then:
      1. Parses the JSON via parse_axe_output()
      2. Writes .verify/web/axe.sarif via write_sarif() (per-check SARIF only)
         NOTE: v0.2 emits per-check SARIF; cross-check SARIF merge into
         .verify/report.sarif is deferred to bead verify-kit-7xm (v0.3).
      3. Returns CheckResult with first envelope on .error

    Timeout: 120s — Playwright + Chromium startup + axe analysis.
    """
    t0 = time.monotonic()

    # Ensure Chromium is available
    install_result = proc_run(
        ["pnpm", "exec", "playwright", "install", "--with-deps", "chromium"],
        cwd=cwd / "web",
        env=clean_env(),
        timeout=300.0,
    )
    if install_result.returncode != 0:
        duration_ms = int((time.monotonic() - t0) * 1000)
        return CheckResult(
            check_id="web.axe",
            status="skip",
            message="Playwright Chromium not available; axe scan skipped",
            duration_ms=duration_ms,
        )

    # Run axe.spec.ts — writes .verify/web/axe.json
    result = proc_run(
        ["pnpm", "exec", "playwright", "test", "axe.spec.ts"],
        cwd=cwd / "web",
        env={**clean_env(), "CI": "1"},
        timeout=120.0,
    )
    duration_ms = int((time.monotonic() - t0) * 1000)

    axe_output = cwd / ".verify" / "web" / "axe.json"
    axe_sarif = cwd / ".verify" / "web" / "axe.sarif"

    # Parse axe output (even if spec "fails" — spec failing means violations found)
    try:
        envelopes = parse_axe_output(axe_output)
    except FileNotFoundError:
        if result.returncode != 0:
            return CheckResult(
                check_id="web.axe",
                status="fail",
                duration_ms=duration_ms,
                error=ErrorEnvelope(
                    code="web.axe.run.failed",
                    message=f"axe.spec.ts exited {result.returncode} and produced no output",
                    hint="Run `cd web && pnpm exec playwright test axe.spec.ts` to debug",
                    fix_command="cd web && pnpm exec playwright test axe.spec.ts",
                    docs_url="https://www.deque.com/axe/",
                ),
            )
        return CheckResult(check_id="web.axe", status="pass", duration_ms=duration_ms)

    # Write per-check SARIF (regardless of pass/fail — enables IDE integration)
    write_sarif(envelopes, axe_sarif)

    if envelopes:
        return CheckResult(
            check_id="web.axe",
            status="fail",
            duration_ms=duration_ms,
            error=envelopes[0],  # first finding; full detail in axe.sarif
        )

    return CheckResult(check_id="web.axe", status="pass", duration_ms=duration_ms)


# ── web.lost_pixel ────────────────────────────────────────────────────────────


@register(
    "web.lost_pixel",
    tier="slow",
    category="visual",
    description=(
        "Lost Pixel visual regression "
        "(Docker-pinned mcr.microsoft.com/playwright:v1.60.0-jammy per D-W02)"
    ),
    # verify-kit-b49: web/src + build config are inputs so a source change
    # invalidates the cached run_id. Declaring only baseline + config let a cache
    # replay keep a stale run_id when web/dist was not rebuilt — a real source
    # change went undetected (false-green, same class as the v0.2 incident).
    inputs=[
        "web/.lost-pixel/baseline/**",
        "web/lostpixel.config.cjs",
        *_WEB_BUILD_INPUTS,
    ],
    fixable=True,
    tool="lost-pixel",
    skip_if_unavailable=True,
)
def check_web_lost_pixel(cwd: Path) -> CheckResult:
    """Run Lost Pixel visual regression inside Docker (comparison mode).

    D-W02: uses Lost Pixel's built-in `lost-pixel docker` mode which pulls
    mcr.microsoft.com/playwright:v1.60.0-jammy and runs comparison inside
    the container — no host node_modules mount (verify-kit-c7k fix).

    If Docker is unavailable, returns status="skip" (not fail) so that agents
    on Docker-less machines do not see a false red (D8-A local-check
    degradation). @register already declares skip_if_unavailable=True.

    COMPARISON mode (subcommand: `lost-pixel docker`):
    exits 1 when diffs are found vs baseline, 0 when they match. The
    baseline-regeneration subcommand always exits 0 — using it here would
    be a silent no-op that never catches regressions. Use `just web-baseline`
    to intentionally regenerate baselines.

    D-W03: the `git add` approval verb flows through ErrorEnvelope.fix_command
    for each diff, surfaced via the existing zero-arg MCP fix_propose() tool
    (verified tools.py.jinja2:144).

    Timeout: 300s — Docker image pull + Lost Pixel comparison across snapshots.
    """
    import os

    t0 = time.monotonic()

    # Detect Docker availability
    inside_docker = Path("/.dockerenv").exists()
    docker_binary = shutil.which("docker")
    docker_env_set = bool(os.environ.get("DOCKER_HOST"))

    if not inside_docker and not docker_binary and not docker_env_set:
        duration_ms = int((time.monotonic() - t0) * 1000)
        # Skip (not fail) when Docker is absent — agents on Docker-less boxes
        # must not see a false red (D8-A local-check degradation). The
        # @register decorator already declares skip_if_unavailable=True;
        # this aligns the runtime return value with that intent.
        return CheckResult(
            check_id="web.lost_pixel",
            status="skip",
            duration_ms=duration_ms,
            message=(
                "Lost Pixel requires Docker for cross-platform reproducibility "
                "(D-W02: pinned to mcr.microsoft.com/playwright:v1.60.0-jammy). "
                "Docker daemon not found — run `just web-baseline` on a machine "
                "with Docker to generate/verify baselines."
            ),
        )

    if inside_docker:
        # Already inside the pinned image — run Lost Pixel in comparison mode directly
        result = proc_run(
            ["pnpm", "exec", "lost-pixel"],
            cwd=cwd / "web",
            env=clean_env(),
            timeout=300.0,
        )
    else:
        # Outside Docker — use Lost Pixel's built-in docker mode (COMPARISON).
        # `lost-pixel docker` owns container orchestration (pulls lostpixel/lost-pixel
        # image, mounts web/ into the container). No host dep directory mount —
        # avoids arm64 vs linux esbuild crash (verify-kit-c7k).
        #
        # Lost Pixel pageShots mode does NOT serve static files — it connects to
        # the baseUrl (host.docker.internal:3000) from inside the container.
        # We must serve web/dist/ on the host first so the container can reach it.
        #
        # verify-kit-b49: ALWAYS rebuild web/dist before serving. The previous
        # `if not dist_dir.exists()` guard only caught a MISSING build — it served
        # whatever STALE dist existed, so a real source change went undetected
        # (false-green, same class as the v0.2 incident). Rebuilding makes the
        # visual comparison reflect the current source.
        build_ok, build_tail = _ensure_web_build(cwd)
        if not build_ok:
            duration_ms = int((time.monotonic() - t0) * 1000)
            return CheckResult(
                check_id="web.lost_pixel",
                status="fail",
                duration_ms=duration_ms,
                error=ErrorEnvelope(
                    code="web.lost_pixel.build.failed",
                    message=(
                        "`pnpm --dir web build` failed before Lost Pixel could "
                        f"screenshot the production build: {build_tail}"
                    ),
                    hint="Fix the build error above; run `cd web && pnpm build` to iterate",
                    fix_command="pnpm --dir web build",
                    docs_url="https://vitejs.dev/guide/build.html",
                ),
            )

        # Start vite preview to serve dist/ at port 3000 (host.docker.internal:3000
        # reaches this from inside the lostpixel container on macOS/Linux Docker).
        preview_proc = subprocess.Popen(
            # --host 0.0.0.0 binds all interfaces so host.docker.internal:3000
            # inside the lostpixel container can reach this preview server.
            # Without 0.0.0.0, vite only listens on 127.0.0.1 (loopback) which
            # is unreachable from Docker containers via host.docker.internal.
            ["pnpm", "--dir", "web", "exec", "vite", "preview",
             "--port", "3000", "--host", "0.0.0.0"],
            cwd=str(cwd),
            env={**clean_env(), "FORCE_COLOR": "0"},
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        try:
            # Give vite preview a moment to bind the port
            time.sleep(2)
            # Use `docker run` directly (not `lost-pixel docker`) so the
            # container's exit code is propagated correctly. `lost-pixel docker`
            # is a convenience wrapper that catches the container exit code and
            # always exits 0 — making it useless as a CI gate.
            # The lostpixel/lost-pixel image already has pnpm + lost-pixel
            # installed; no host dep directory mount needed (verify-kit-c7k fix).
            # MUST be absolute: docker -v / WORKSPACE reject relative mount paths
            # ("invalid mount path: 'web' must be absolute" → exit 125). The verify
            # runner passes a relative cwd, so `cwd / "web"` is relative; the other
            # web checks survive it (it's only a *subprocess* cwd) but docker's
            # bind-mount flag does not. Resolve before building the docker args.
            web_dir = (cwd / "web").resolve()
            version_result = proc_run(
                ["pnpm", "exec", "lost-pixel", "--version"],
                cwd=web_dir,
                capture_output=True,
                text=True,
                timeout=10.0,
            )
            lp_version = version_result.stdout.strip().split("\n")[-1].strip() if version_result.returncode == 0 else "3.22.0"
            result = proc_run(
                [
                    "docker", "run", "--rm",
                    # host.docker.internal is built in on Docker Desktop (macOS/Windows)
                    # but NOT on Linux — without this, the container cannot reach the
                    # host's vite preview at host.docker.internal:3000 and Lost Pixel
                    # captures a blank/errored page (verify-kit-i7n). Harmless on
                    # Docker Desktop where the name already resolves.
                    "--add-host", "host.docker.internal:host-gateway",
                    "-v", f"{web_dir}:{web_dir}",
                    "-e", f"WORKSPACE={web_dir}",
                    "-e", "DOCKER=1",
                    "-e", "LOST_PIXEL_DISABLE_TELEMETRY=1",
                    f"lostpixel/lost-pixel:v{lp_version}",
                ],
                cwd=web_dir,
                env=clean_env(),
                timeout=300.0,
            )
        finally:
            preview_proc.terminate()
            try:
                preview_proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                preview_proc.kill()

    duration_ms = int((time.monotonic() - t0) * 1000)

    if result.returncode not in (0, 1):
        # Non-0/1 exit = Lost Pixel itself crashed (not just diffs found).
        # Surface the subprocess stderr/stdout tail: exit 125 in particular is
        # the Docker daemon failing *before* the container runs (bad image tag,
        # pull/rate-limit, mount or --add-host error), and the bare exit code
        # alone is undebuggable. A check that hides why it failed defeats the
        # purpose — give the reader the actual daemon message.
        diag = (result.stderr or "").strip() or (result.stdout or "").strip()
        diag_tail = diag[-600:] if diag else "(no stderr/stdout captured)"
        return CheckResult(
            check_id="web.lost_pixel",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.lost_pixel.run.failed",
                message=f"lost-pixel exited {result.returncode} (unexpected crash): {diag_tail}",
                hint="Run `just web-baseline` to debug inside Docker",
                fix_command="just web-baseline",
                docs_url="https://lost-pixel.com/docs",
            ),
        )

    # Lost Pixel OSS signals comparison results via the EXIT CODE, not a results
    # file (it never writes comparison-results.json — that is a SaaS artifact):
    #   exit 0 → no differences → pass
    #   exit 1 → diffs found; one PNG per differing snapshot under difference/
    # (exit >1 was handled above as a crash.) --require freshness is enforced
    # generically by the runner via run_id (a cache-replay keeps a stale run_id
    # and fails) — the check always runs lost-pixel, so its exit code is fresh.
    lostpixel_dir = cwd / "web" / ".lost-pixel"

    if result.returncode == 0:
        return CheckResult(
            check_id="web.lost_pixel",
            status="pass",
            duration_ms=duration_ms,
        )

    # returncode == 1 → differences found. parse_lostpixel_output turns each
    # difference PNG into an ErrorEnvelope (D-W03 git-add approval verb).
    envelopes = parse_lostpixel_output(lostpixel_dir)
    if not envelopes:
        # Exit 1 but no difference PNG on disk — unexpected. Surface the run
        # output rather than reporting a phantom pass.
        diag = (result.stdout or "").strip() or (result.stderr or "").strip()
        envelopes = [
            ErrorEnvelope(
                code="web.lost_pixel.diff.unknown",
                message=(
                    "Lost Pixel reported differences (exit 1) but wrote no diff PNG "
                    f"under {lostpixel_dir / 'difference'}. Output: "
                    f"{diag[-400:] if diag else '(none)'}"
                ),
                hint="Run `just web-baseline` in Docker to inspect the comparison.",
                fix_command="just web-baseline",
                docs_url="https://lost-pixel.com/docs",
            )
        ]
    return CheckResult(
        check_id="web.lost_pixel",
        status="fail",
        duration_ms=duration_ms,
        error=envelopes[0],  # first diff; D-W03 git add in fix_command
    )


# ── web.otel_trace ────────────────────────────────────────────────────────────


@register(
    "web.otel_trace",
    tier="slow",
    category="otel",
    description=(
        "Browser→FastAPI trace connectivity assertion "
        "(WEB_SERVICE_NAME + api spans, shared traceID, per-run UUID marker"
        "{% if has_db %}; DB span asserted when has_db=true{% endif %})"
    ),
    inputs=["web/src/otel.ts", "web/tests/e2e/trace-demo.spec.ts"],
    fixable=False,
    tool="playwright",
    skip_if_unavailable=True,
)
def check_web_otel_trace(cwd: Path) -> CheckResult:
    """Assert the browser→FastAPI→DB trace connected end-to-end.

    Runtime-gated (P9-06): registered unconditionally; returns a LOUD
    status="skip" when the required config env vars are absent so the check
    is always discoverable via `verify-kit list-checks` but never raises on
    unconfigured stacks.

    Failure-state table (D9-INT-11/12):
      config absent       → skip (LOUD message naming the missing vars)
      Jaeger unreachable  → skip (infra absent, not a trace failure)
      readiness/driver fail → fail
      trace not found     → fail + diagnostics (D-11)
      mid-run errors      → fail + diagnostics

    Connectivity assertion (D-04, BL-5):
      >=1 trace for the per-run UUID marker
      spans from >=2 distinct services including WEB_SERVICE_NAME (browser
        client/fetch span — BL-5) AND the api service
      >=1 DB span (SQLAlchemy SELECT, matched by tolerant regex)
      all spans share ONE traceID

    Consumer config (F-05): env Jaeger query URL + api service name only;
    DB-span match is a hardcoded tolerant regex.

    No module-scope imports from app/ — all backend interaction is HTTP/Jaeger.
    """
    import uuid

    t0 = time.monotonic()

    # ── Config (F-05): env Jaeger query URL + api service name ────────────────
    jaeger_base_url = os.environ.get("JAEGER_QUERY_BASE_URL", "http://localhost:16686")
    api_service_name = os.environ.get("OTEL_SERVICE_NAME", "")
    web_service_name = os.environ.get(
        "VITE_OTEL_SERVICE_NAME",
        # Fallback: derive from project directory name (<project>-web convention)
        f"{cwd.name}-web",
    )

    # Loud skip when required config is absent (runtime-gated, P9-06)
    if not api_service_name:
        duration_ms = int((time.monotonic() - t0) * 1000)
        return CheckResult(
            check_id="web.otel_trace",
            status="skip",
            duration_ms=duration_ms,
            message=(
                "web.otel_trace: OTEL_SERVICE_NAME not set — cannot assert the api "
                "service span. Set OTEL_SERVICE_NAME=<project>-api (matches docker-compose "
                "OTEL_SERVICE_NAME) to enable this check. Jaeger URL: "
                f"JAEGER_QUERY_BASE_URL (default {jaeger_base_url})."
            ),
        )

    # ── Generate per-run UUID for the trace correlation marker ────────────────
    trace_test_id = str(uuid.uuid4())

    # ── Ensure Playwright/Chromium is available ───────────────────────────────
    install_result = proc_run(
        ["pnpm", "exec", "playwright", "install", "--with-deps", "chromium"],
        cwd=cwd / "web",
        env=clean_env(),
        timeout=300.0,
    )
    if install_result.returncode != 0:
        duration_ms = int((time.monotonic() - t0) * 1000)
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.chromium.unavailable",
                message="Playwright Chromium install failed; cannot drive the real-browser trace",
                hint=(
                    "Run `cd web && pnpm exec playwright install chromium` "
                    "or ensure the Playwright Docker image is available"
                ),
                fix_command="cd web && pnpm exec playwright install chromium",
                docs_url="https://playwright.dev/docs/browsers",
            ),
        )

    # ── Drive the real-browser click via trace-demo.spec.ts ──────────────────
    # Pass the per-run UUID via PLAYWRIGHT_TRACE_TEST_ID env so the spec can
    # use it if needed (the spec also generates its own UUID via the URL param).
    spec_env = {
        **clean_env(),
        "CI": "1",
        "PLAYWRIGHT_TRACE_TEST_ID": trace_test_id,
        # Enable the browser OTel SDK: point it at Jaeger OTLP-HTTP :4318
        "VITE_OTEL_EXPORTER_OTLP_ENDPOINT": os.environ.get(
            "VITE_OTEL_EXPORTER_OTLP_ENDPOINT", "http://localhost:4318/v1/traces"
        ),
    }
    playwright_result = proc_run(
        ["pnpm", "exec", "playwright", "test", "trace-demo.spec.ts"],
        cwd=cwd / "web",
        env=spec_env,
        timeout=120.0,
    )

    # Read back the trace_test_id written by the spec (the spec generates its own UUID)
    trace_id_file = cwd / ".verify" / "web" / "trace_test_id.json"
    effective_trace_test_id = trace_test_id
    if trace_id_file.exists():
        try:
            data = json.loads(trace_id_file.read_text())
            effective_trace_test_id = data.get("trace_test_id", trace_test_id)
        except (json.JSONDecodeError, KeyError):
            pass

    if playwright_result.returncode != 0:
        duration_ms = int((time.monotonic() - t0) * 1000)
        diag = (
            f"trace_test_id={effective_trace_test_id!r} | "
            f"Jaeger query URL: {jaeger_base_url}/api/traces | "
            f"api_service={api_service_name!r} web_service={web_service_name!r}"
        )
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.driver.failed",
                message=(
                    f"Playwright trace-demo.spec.ts exited {playwright_result.returncode}. "
                    f"{diag}"
                ),
                hint=(
                    "Ensure the dev stack is running (`just trace-up`), "
                    "VITE_OTEL_EXPORTER_OTLP_ENDPOINT points at Jaeger :4318, "
                    "and OTEL_SERVICE_NAME matches the api service"
                ),
                fix_command="just trace-up",
                docs_url="https://opentelemetry.io/docs/",
            ),
        )

    # ── Poll Jaeger for the trace by tag ──────────────────────────────────────
    # Import at function scope — no module-level app/ dependency (F-05)
    from harness.jaeger import poll_trace_by_tag  # noqa: PLC0415

    # Jaeger's /api/traces REQUIRES a `service` param (omitting it → HTTP 400).
    # Query by the browser/web service, which carries the per-run trace_test_id
    # tag (BL-5); Jaeger returns the FULL matching trace (web + api + db spans),
    # so the connectivity assertion below still sees every service.
    jaeger_result = poll_trace_by_tag(
        effective_trace_test_id,
        service=web_service_name,
        require_services={web_service_name, api_service_name},
        timeout=20.0,
        poll_interval=1.5,
    )

    duration_ms = int((time.monotonic() - t0) * 1000)

    diag_suffix = (
        f"trace_test_id={effective_trace_test_id!r} | "
        f"query_url={jaeger_result.query_url or jaeger_base_url + '/api/traces'!r} | "
        f"api_service={api_service_name!r} web_service={web_service_name!r} | "
        f"query_errors={jaeger_result.query_errors!r}"
    )

    # Jaeger unreachable → skip (infra absent, not a trace failure, F5)
    if jaeger_result.status == "unreachable":
        return CheckResult(
            check_id="web.otel_trace",
            status="skip",
            duration_ms=duration_ms,
            message=(
                f"web.otel_trace: Jaeger query endpoint unreachable at "
                f"{jaeger_base_url}. Start the stack with `just trace-up`. | {diag_suffix}"
            ),
        )

    # Trace not found within timeout → fail with diagnostics (D-11)
    if jaeger_result.status == "not_found":
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.trace.not_found",
                message=(
                    f"No trace found in Jaeger for trace_test_id={effective_trace_test_id!r} "
                    f"within timeout. The browser or api span may not have exported. "
                    f"{diag_suffix}"
                ),
                hint=(
                    "Check that VITE_OTEL_EXPORTER_OTLP_ENDPOINT is set to Jaeger :4318 "
                    "at build time, and OTEL_EXPORTER_OTLP_ENDPOINT is set for FastAPI. "
                    "Run `just trace-up` to start the stack."
                ),
                fix_command="just trace-up",
                docs_url="https://www.jaegertracing.io/docs/",
            ),
        )

    # ── Connectivity assertion (D-04, BL-5) ───────────────────────────────────
    traces = jaeger_result.traces
    all_spans: list[dict] = []
    for tr in traces:
        all_spans.extend(tr.get("spans") or [])

    # Helper: get service name from a span (spans carry processID; processes map is in trace)
    def _service_of_span(span: dict, trace_dict: dict) -> str:
        proc_id = span.get("processID", "")
        processes = trace_dict.get("processes") or {}
        proc = processes.get(proc_id) or {}
        svc = proc.get("serviceName", "")
        if svc:
            return svc
        # Fallback: check span.process inline (some Jaeger versions)
        return (span.get("process") or {}).get("serviceName", "")

    # Build service→spans mapping from all traces
    service_spans: dict[str, list[dict]] = {}
    for tr in traces:
        for span in tr.get("spans") or []:
            svc = _service_of_span(span, tr)
            service_spans.setdefault(svc, []).append(span)

    distinct_services = set(service_spans.keys()) - {""}

    # Assert WEB_SERVICE_NAME browser span present (BL-5)
    web_service_present = web_service_name in distinct_services
    if not web_service_present:
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.browser_span.missing",
                message=(
                    f"No WEB_SERVICE_NAME={web_service_name!r} browser span found in trace. "
                    f"Found services: {sorted(distinct_services)!r}. "
                    f"A backend-only trace cannot pass this check (BL-5). {diag_suffix}"
                ),
                hint=(
                    "Ensure the browser OTel SDK is active (VITE_OTEL_EXPORTER_OTLP_ENDPOINT "
                    "set at build time, pointing at Jaeger :4318). "
                    f"Expected service.name={web_service_name!r} in a browser fetch span."
                ),
                fix_command="just trace-up",
                docs_url="https://opentelemetry.io/docs/",
            ),
        )

    # Assert api service span present
    api_service_present = api_service_name in distinct_services
    if not api_service_present:
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.api_span.missing",
                message=(
                    f"No api service={api_service_name!r} span found in trace. "
                    f"Found services: {sorted(distinct_services)!r}. {diag_suffix}"
                ),
                hint=(
                    "Ensure OTEL_SERVICE_NAME and OTEL_EXPORTER_OTLP_ENDPOINT are set "
                    "for the FastAPI process. Check docker-compose.yml service config."
                ),
                fix_command="just trace-up",
                docs_url="https://opentelemetry.io/docs/",
            ),
        )

    # Assert >=1 DB span (tolerant regex matching SQLAlchemy SELECT queries)
    # WR-01: only assert the DB span in DB-enabled scaffolds. In has_db=false
    # renders, /trace-demo returns {"db": false} and emits no SQLAlchemy span —
    # asserting one would produce false failures on legitimate no-DB stacks.
    # Browser and API service span assertions above remain unconditional (BL-5).
{% if has_db %}
    import re

    _DB_SPAN_RE = re.compile(
        r"SELECT|sqlalchemy|db\.|database|postgres|sqlite|mysql",
        re.IGNORECASE,
    )
    db_span_found = any(
        _DB_SPAN_RE.search(span.get("operationName", ""))
        for span in all_spans
    )
    if not db_span_found:
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.db_span.missing",
                message=(
                    f"No DB span found in trace (regex: SELECT|sqlalchemy|db.|database|...). "
                    f"Span operations: {[s.get('operationName') for s in all_spans]!r}. "
                    f"{diag_suffix}"
                ),
                hint=(
                    "Ensure SQLAlchemy instrumentation is active and the DB is reachable. "
                    "Check that OTEL_EXPORTER_OTLP_ENDPOINT is set for FastAPI."
                ),
                fix_command="just trace-up",
                docs_url="https://opentelemetry.io/docs/",
            ),
        )
{% endif %}

    # Assert all spans share ONE traceID (cross-service propagation check)
    trace_ids = {tr.get("traceID") for tr in traces if tr.get("traceID")}
    if len(trace_ids) > 1:
        return CheckResult(
            check_id="web.otel_trace",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.otel_trace.trace_id.fragmented",
                message=(
                    f"Spans from different services have different traceIDs: {trace_ids!r}. "
                    f"Expected all services to share ONE traceID (W3C traceparent propagation). "
                    f"{diag_suffix}"
                ),
                hint=(
                    "Ensure FetchInstrumentation propagates the W3C traceparent header "
                    "and FastAPI/OTel propagates it through to the DB. "
                    "Check CORS expose_headers includes 'traceparent'."
                ),
                fix_command="just trace-up",
                docs_url="https://opentelemetry.io/docs/",
            ),
        )

    return CheckResult(
        check_id="web.otel_trace",
        status="pass",
        duration_ms=duration_ms,
    )


# ── web.typecheck ─────────────────────────────────────────────────────────────

# tsc --pretty false emits one diagnostic per line:
#   path/to/File.tsx(12,9): error TS2322: Type 'x' is not assignable to type 'y'.
# Capture: file, line, column, TS error code, message. The leading anchor keeps
# us on the FIRST real diagnostic line (tsc prints them in source order).
import re as _re  # noqa: E402 — module-local alias; re isn't imported at top

_TSC_DIAG_RE = _re.compile(
    r"^(?P<file>[^(]+)\((?P<line>\d+),(?P<col>\d+)\):\s+"
    r"error\s+(?P<code>TS\d+):\s+(?P<msg>.*)$",
    _re.MULTILINE,
)


@register(
    "web.typecheck",
    tier="standard",
    category="typecheck",
    description="TypeScript static type-check for web/ (tsc --noEmit)",
    inputs=["web/**/*.ts", "web/**/*.tsx", "web/tsconfig.json", "web/package.json"],
    fixable=False,
    tool="tsc",
    skip_if_unavailable=True,  # tsc may not be installed offline (no node_modules)
)
def check_web_typecheck(cwd: Path) -> CheckResult:
    """Run `tsc --noEmit` over web/ to catch TS type errors `just verify` misses.

    Vite NEVER type-checks during build (esbuild transpiles and drops types), so
    a standard `just verify` is blind to TypeScript type errors today. This check
    closes that gap by running the compiler in --noEmit mode.

    Offline-first (subprocess discipline): tsc is a Node tool, so we resolve the
    LOCAL binary at web/node_modules/.bin/tsc first. When it is absent (offline,
    no `pnpm install`), the check returns status="skip" — never auto-fetches and
    never fails a Docker-less / offline run (D8-A local-check degradation;
    skip_if_unavailable=True). cwd=cwd/"web" + clean_env() mirror the sibling
    web checks so pnpm/node resolve against the scaffold's own toolchain.

    On a non-zero tsc exit, the FIRST `tsc --pretty false` diagnostic is parsed
    into a clickable ErrorEnvelope (code="web.typecheck.TSxxxx", file/line/column).
    """
    t0 = time.monotonic()

    # Offline-first: skip when the LOCAL tsc binary is not installed (no
    # node_modules). We gate on the project-local bin only — `pnpm exec tsc`
    # resolves the scaffold's own tsc against web/node_modules, so a global tsc
    # on PATH is not a usable substitute (it would run without the project's
    # installed deps and produce a noisy fail). NEVER auto-fetch via pnpm dlx —
    # a missing toolchain is a skip, not a fail (same posture as web.lost_pixel's
    # Docker probe; skip_if_unavailable=True).
    tsc_bin = cwd / "web" / "node_modules" / ".bin" / "tsc"
    if not tsc_bin.exists():
        duration_ms = int((time.monotonic() - t0) * 1000)
        return CheckResult(
            check_id="web.typecheck",
            status="skip",
            duration_ms=duration_ms,
            message=(
                "web.typecheck: tsc not found at web/node_modules/.bin/tsc — "
                "run `cd web && pnpm install` to enable the TypeScript type gate "
                "(offline-first: never auto-fetched)."
            ),
        )

    result = proc_run(
        # --pretty false → stable machine-parseable `file(line,col): error TSxxxx`
        # diagnostics (the default colorized/pretty format wraps + adds frames).
        ["pnpm", "exec", "tsc", "--noEmit", "--pretty", "false"],
        cwd=cwd / "web",
        env=clean_env(),
        timeout=120.0,
    )
    duration_ms = int((time.monotonic() - t0) * 1000)

    if result.returncode == 0:
        return CheckResult(
            check_id="web.typecheck",
            status="pass",
            duration_ms=duration_ms,
        )

    # Non-zero exit → type errors (or a tsc invocation error). tsc writes
    # diagnostics to stdout; fall back to stderr for invocation failures.
    output = (result.stdout or "") + (result.stderr or "")
    match = _TSC_DIAG_RE.search(output)
    if match is None:
        # tsc exited non-zero but emitted no parseable diagnostic (e.g. a config
        # error or a tsc crash). Surface the output tail rather than a phantom pass.
        diag = output.strip()
        diag_tail = diag[-800:] if diag else "(no tsc output captured)"
        return CheckResult(
            check_id="web.typecheck",
            status="fail",
            duration_ms=duration_ms,
            error=ErrorEnvelope(
                code="web.typecheck.run.failed",
                message=(
                    f"tsc --noEmit exited {result.returncode} "
                    f"(no parseable diagnostic): {diag_tail}"
                ),
                hint="Run `cd web && pnpm exec tsc --noEmit` to see the full error",
                fix_command="cd web && pnpm exec tsc --noEmit",
                docs_url="https://www.typescriptlang.org/docs/handbook/compiler-options.html",
            ),
        )

    ts_code = match.group("code")
    return CheckResult(
        check_id="web.typecheck",
        status="fail",
        duration_ms=duration_ms,
        error=ErrorEnvelope(
            code=f"web.typecheck.{ts_code}",
            message=f"{ts_code}: {match.group('msg').strip()}",
            hint=(
                "Fix the type error, or run "
                "`cd web && pnpm exec tsc --noEmit` to see all diagnostics"
            ),
            fix_command="cd web && pnpm exec tsc --noEmit",
            docs_url="https://www.typescriptlang.org/docs/handbook/compiler-options.html",
            file=match.group("file").strip(),
            line=int(match.group("line")),
            column=int(match.group("col")),
        ),
    )
