"""harness.checks — trigger-import every check submodule so @register() fires.

Importing this subpackage is the side-effecting step that populates
`harness.registry._checks`. harness.cli imports this package once at
startup; tests import it to introspect the catalog.

This module exports nothing — it exists solely for the import side-effect.
The `as _xxx` aliases prevent shadowing the builtin `format` name when the
`format` submodule is added in Task 2.
"""

from harness.checks import copier as _copier  # noqa: F401
from harness.checks import deps as _deps  # noqa: F401
from harness.checks import fixloop as _fixloop  # noqa: F401
from harness.checks import format as _format  # noqa: F401
from harness.checks import just_list as _just_list  # noqa: F401
from harness.checks import lint as _lint  # noqa: F401
from harness.checks import meta as _meta  # noqa: F401
from harness.checks import mise as _mise  # noqa: F401
from harness.checks import security as _security  # noqa: F401
from harness.checks import typecheck as _typecheck  # noqa: F401

{% if has_backend %}
# Architectural import-boundary check — imported for @register side-effect.
from harness.checks import arch as _arch  # noqa: F401

# Backend slice check — imported for @register side-effect.
from harness.checks import backend as _backend  # noqa: F401

{% endif %}
{% if has_llm %}
# Optional eval check — imported for @register side-effect.
# Returns status="skip" with a hint pointing at `just eval`; discoverable via
# `verify-kit list-checks` but never runs in the umbrella `just verify`.
from harness.checks import eval as _eval  # noqa: F401
{% endif %}
{% if has_web %}
# Web add-on checks — imported for @register side-effect.
# Registers: web.vitest, web.playwright, web.lighthouse, web.axe, web.lost_pixel
from harness.checks import web as _web  # noqa: F401
{% endif %}
