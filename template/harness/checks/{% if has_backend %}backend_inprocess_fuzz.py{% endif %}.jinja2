"""harness.checks.backend_inprocess_fuzz — schemathesis against the in-process ASGI app.

Invoked by `harness.checks.backend.run()` (via subprocess) when the live app
on localhost:8000 is unreachable. Loads `app.main:create_app`, constructs the
ASGI app, and runs schemathesis against it in-process via ASGITransport so no
requests leave the process and no socket bind is required.

This file closes the silent-skip gap: previously,
`just verify` (which does NOT bring up docker) silently skipped the
schemathesis fuzz step, leaving API-18 unproven in the umbrella verify path.

Usage:
    uv run python -m harness.checks.backend_inprocess_fuzz [--max-examples N] [--cwd PATH]
"""

from __future__ import annotations

import argparse
import asyncio
import sys
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run schemathesis fuzz against the FastAPI app in-process."
    )
    parser.add_argument(
        "--max-examples",
        type=int,
        default=10,
        help="Hypothesis max_examples per operation (default: 10)",
    )
    # REVIEW-CHECKLIST §1: cwd must be taken explicitly. The default
    # Path.cwd().resolve() is acceptable here ONLY because the harness runner
    # calls this module as a subprocess with cwd=cwd already set to the
    # scaffold root. The --cwd flag allows the backend check (T02) to pass
    # the scaffold root explicitly for hermetic execution.
    parser.add_argument(
        "--cwd", type=Path, default=None, help="Scaffold root directory (defaults to process cwd)"
    )
    args = parser.parse_args()

    scaffold_root = args.cwd.resolve() if args.cwd else Path.cwd().resolve()

    # Import the FastAPI app from the scaffolded project. `create_app` accepts
    # an explicit cwd so it never calls Path.cwd() internally (REVIEW-CHECKLIST §1).
    try:
        from app.main import create_app
    except ImportError as exc:
        print(
            f"ERROR: cannot import app.main from {scaffold_root}: {exc}\n"
            "Ensure `uv pip install -e .` was run in the scaffold root.",
            file=sys.stderr,
        )
        return 1

    app = create_app(cwd=scaffold_root)

    # Override require_auth so schemathesis-generated requests are not blocked
    # by the global auth dependency. Auth correctness is covered by
    # tests/test_phase06_auth_polarity.py at the repo root; this fuzz check
    # validates schema conformance, not auth.
    try:
        from app.auth import require_auth

        app.dependency_overrides[require_auth] = lambda: None
    except ImportError:
        # auth module is optional; if absent, no override is needed.
        pass

    # schemathesis public ASGI API (>=3.36): `openapi.from_asgi` loads the
    # schema from the running app's `/openapi.json` route and routes generated
    # requests through the ASGI app in-process (no socket bind needed). This is
    # the documented in-process testing path for ASGI apps.
    try:
        import schemathesis
        import schemathesis.engine.events as ev
        from schemathesis.engine import Status
    except ImportError as exc:
        print(f"ERROR: schemathesis not installed: {exc}", file=sys.stderr)
        return 1

    # Enter the FastAPI lifespan before schemathesis loads the schema. The
    # schema-load step hits `/openapi.json` via TestClient(app), and any
    # middleware that reads `app.state.settings` (bound inside lifespan) would
    # otherwise raise AttributeError. asgi-lifespan's LifespanManager is the
    # documented pattern for this. See:
    # https://github.com/florimondmanca/asgi-lifespan
    try:
        from asgi_lifespan import LifespanManager
    except ImportError as exc:
        print(f"ERROR: asgi-lifespan not installed: {exc}", file=sys.stderr)
        return 1

    async def _load_schema_with_lifespan():
        async with LifespanManager(app):
            return schemathesis.openapi.from_asgi("/openapi.json", app)

    schema = asyncio.run(_load_schema_with_lifespan())

    # Scope this check to schema/spec conformance only — the API-18 promise.
    # Schemathesis 4.x ships additional adversarial checks
    # (negative_data_rejection, missing_required_header, ignored_auth) that
    # are useful in their own right but require dedicated handler design
    # (custom error responses for invalid bodies, required-header policy,
    # auth-coverage strategy). They're out of scope for the in-process fuzz
    # smoke check; track separately if/when the scaffold adopts them.
    schema.config.checks.update(
        excluded_check_names=[
            "negative_data_rejection",
            "missing_required_header",
            "ignored_auth",
            "positive_data_acceptance",
        ]
    )
    # Thread --max-examples through to the hypothesis engine. The schemathesis
    # 4.x API surfaces max_examples on schema.config.generation, not on
    # engine.from_schema(). Without this update the engine runs the default
    # 100 examples per operation regardless of the CLI flag, and the success
    # banner below misreports honored count. Phase 4 04-VALIDATION.md GAP-06.
    schema.config.generation.update(max_examples=args.max_examples)
    engine = schemathesis.engine.from_schema(schema)

    # Iterate the engine event stream. Failures appear as SuiteFinished or
    # ScenarioFinished events with status=FAILURE or ERROR.
    suite_failures: list[str] = []
    for event in engine.execute():
        if isinstance(event, ev.SuiteFinished):
            if event.status in (Status.FAILURE, Status.ERROR):
                # SuiteFinished exposes `phase` (PhaseName enum), not `label`.
                # Scenario-level labels live on ScenarioFinished events.
                suite_failures.append(
                    f"Suite phase={event.phase.name} finished with status={event.status.name}"
                )
        if isinstance(event, ev.EngineFinished):
            # Engine completed; stop_reason == COMPLETED means no early abort.
            pass

    if suite_failures:
        print("schemathesis (in-process) failures:", file=sys.stderr)
        for f in suite_failures:
            print(f"  - {f}", file=sys.stderr)
        return 1

    print(
        f"schemathesis (in-process) OK — ran against {scaffold_root} via ASGITransport "
        f"(max_examples={args.max_examples})"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
