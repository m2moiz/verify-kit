"""harness.mcp._describe — shared `describe` payload builder (Plan 03-01 T04).

Both the CLI ``verify-kit describe`` command and the MCP ``describe`` tool
call :func:`describe_envelope` so the byte-identical contract (Plan 03-01
T08 Category A) is enforced by construction — there's only one payload
builder.

Kept under ``harness.mcp`` (rather than ``harness``) because Phase-2's
``harness.cli`` module pre-existed and inlined the envelope; this helper
exists to support the new MCP tool without rewriting Phase-2 CLI internals
beyond a thin call-out.
"""
from __future__ import annotations

from harness.models import (
    EXIT_BAD_INPUT,
    EXIT_CACHE_CORRUPT,
    EXIT_CHECK_FAIL,
    EXIT_OK,
    EXIT_OTEL_UNREACHABLE,
    EXIT_TOOL_MISSING,
    EXIT_WRITE_FAILED,
    CheckCatalogEntry,
    VerifyReport,
)
from harness.registry import list_checks as _registry_list_checks


def describe_envelope() -> dict:
    """Return the FMT-04 introspection envelope as a plain dict.

    Shape is identical to the JSON that ``verify-kit describe --format=json``
    emits (Plan 03-01 T08 Category A).
    """
    commands_info = [
        {"name": "verify", "help": "Run verification checks."},
        {"name": "list-checks", "help": "List registered checks."},
        {"name": "describe", "help": "Emit the introspection envelope."},
        {"name": "trace", "help": "Render the most recent verify-kit trace."},
        {"name": "mcp", "help": "verify-kit MCP server (Plan 03-01)."},
        {"name": "ralph", "help": "Ralph loop wrapper (Plan 03-02)."},
    ]
    payload = {
        "version": "1",
        "commands": commands_info,
        "exit_codes": {
            "EXIT_OK": EXIT_OK,
            "EXIT_CHECK_FAIL": EXIT_CHECK_FAIL,
            "EXIT_BAD_INPUT": EXIT_BAD_INPUT,
            "EXIT_CACHE_CORRUPT": EXIT_CACHE_CORRUPT,
            "EXIT_TOOL_MISSING": EXIT_TOOL_MISSING,
            "EXIT_WRITE_FAILED": EXIT_WRITE_FAILED,
            "EXIT_OTEL_UNREACHABLE": EXIT_OTEL_UNREACHABLE,
        },
        "exit_code_precedence": [
            "EXIT_WRITE_FAILED supersedes EXIT_CHECK_FAIL when .verify/report.* cannot be written",
        ],
        "check_catalog_schema": CheckCatalogEntry.model_json_schema(
            mode="serialization"
        ),
        "report_schema": VerifyReport.model_json_schema(mode="serialization"),
        "checks": [
            CheckCatalogEntry.from_spec(s).model_dump()
            for s in _registry_list_checks()
        ],
        "jsonl_summary_marker": {
            "type": "summary",
            "fields": [
                "pass_count",
                "fail_count",
                "skip_count",
                "total",
                "duration_ms",
                "exit_code",
            ],
        },
    }
    return payload


__all__ = ["describe_envelope"]
