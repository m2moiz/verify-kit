"""harness.jaeger — minimal client for the Jaeger HTTP API.

Phase-2 scope (per RESEARCH.md §9): fetch the most recent verify-kit trace
and render it as a Rich tree/waterfall. ``trace --last`` reads from
``http://localhost:16686/api/traces?service=verify-kit&limit=1``.

Phase-9 extension (F5/D-02/F-05): ``poll_trace_by_tag`` polls Jaeger
by a tag value (verify_kit.trace_test_id=<uuid>) and returns a structured
``TraceResult`` that distinguishes:
  - status="unreachable"  — collector/query not reachable (caller → skip)
  - status="not_found"    — reachable but trace absent within timeout (→ fail)
  - status="found"        — trace(s) present; carries spans/traceID data

Tags are encoded via json.dumps and passed as ``httpx params={"tags": ...}``
— NEVER hand-concatenated (F-05: sole Jaeger-query chokepoint in this module).

UX-06 graceful degradation: when the Jaeger query service is unreachable
(``httpx.RequestError`` / ``HTTPStatusError``), ``fetch_latest_trace`` returns
``None`` — the CLI then exits ``EXIT_OTEL_UNREACHABLE`` with a hint to run
``just trace-up`` first, never raises.

Trust boundary: Jaeger is bound to localhost by ``docker run -p 16686:16686``
(see ``justfile``). Untrusted-but-local; httpx ``timeout=2.0`` prevents hangs.
"""

from __future__ import annotations

import json
import os
import time
from dataclasses import dataclass, field
from typing import Any, Literal

import httpx
from rich.console import Console
from rich.tree import Tree

JAEGER_QUERY_URL = "http://localhost:16686/api/traces"

# Env-overridable base URL for the Jaeger HTTP query API (F-05).
# Change JAEGER_QUERY_BASE_URL to point at a remote instance.
def _jaeger_base_url() -> str:
    return os.environ.get("JAEGER_QUERY_BASE_URL", "http://localhost:16686")


# ── Structured result for tag-filtered polling (F5, D-02) ────────────────────


TraceResultStatus = Literal["found", "not_found", "unreachable"]


@dataclass
class TraceResult:
    """Structured result from poll_trace_by_tag.

    status:
      "found"       — trace(s) with the requested tag found within timeout.
                      ``traces`` carries the raw Jaeger trace dicts.
      "not_found"   — Jaeger was reachable but no matching trace appeared
                      within the polling timeout. Caller should treat as fail.
      "unreachable" — Jaeger query endpoint could not be reached at the
                      connection level (httpx.RequestError: DNS/connect/timeout).
                      Caller should treat as skip (infrastructure absent).
                      A non-2xx HTTP response is NOT unreachable (Jaeger
                      responded) — that maps to "not_found" so it fails loudly.
    """

    status: TraceResultStatus
    traces: list[dict[str, Any]] = field(default_factory=list)
    # Raw Jaeger response errors (if any) returned by the query API
    query_errors: list[Any] = field(default_factory=list)
    # URL used for the last query (for diagnostics)
    query_url: str = ""


def poll_trace_by_tag(
    trace_test_id: str,
    *,
    timeout: float = 15.0,
    poll_interval: float = 1.0,
    service: str | None = None,
    require_services: set[str] | None = None,
) -> TraceResult:
    """Poll Jaeger for a trace tagged with verify_kit.trace_test_id=<uuid>.

    Polls up to ``timeout`` seconds at ``poll_interval`` intervals.  The tags
    parameter is encoded via ``json.dumps`` and passed as an httpx query param
    — NEVER hand-concatenated (F-05).

    Args:
        trace_test_id:  Per-run UUID set as a browser span attribute and as
                        the ``?trace_test_id=`` query param on /trace-demo.
        timeout:        Maximum total seconds to wait.  Should be >= batch
                        export delay (OTel BatchSpanProcessor default ≈5s).
        poll_interval:  Seconds between polls.
        service:        Optional Jaeger service filter.  When omitted, the
                        tag filter alone narrows results (cross-service lookup).
        require_services: When set, a trace counts as "found" only once spans
                        from ALL these service names are present. The browser
                        span force-flushes immediately but server/DB spans
                        arrive ~5s later (BatchSpanProcessor); without this the
                        first (browser-only) snapshot returns and the caller's
                        connectivity assertion fails on an incomplete trace.

    Returns:
        TraceResult with status "found", "not_found", or "unreachable".
    """
    base_url = _jaeger_base_url()
    traces_url = f"{base_url}/api/traces"

    params: dict[str, Any] = {
        "tags": json.dumps({"verify_kit.trace_test_id": trace_test_id}),
        "limit": 20,
    }
    if service:
        params["service"] = service

    deadline = time.monotonic() + timeout
    last_query_url = traces_url
    last_errors: list[Any] = []

    while True:
        try:
            resp = httpx.get(traces_url, params=params, timeout=5.0)
            resp.raise_for_status()
        except httpx.RequestError:
            # Connection-level failure — the Jaeger query endpoint is truly not
            # reachable (DNS/connect/timeout). Caller maps "unreachable" → skip.
            return TraceResult(
                status="unreachable",
                query_url=traces_url,
            )
        except httpx.HTTPStatusError as exc:
            # Jaeger RESPONDED with a non-2xx (e.g. 400 bad query params, 5xx).
            # It IS reachable — classifying this as "unreachable" would hide a
            # real query bug behind a skip (the F5 carve-out). Treat as
            # not_found-class so the caller FAILS, surfacing the HTTP error.
            return TraceResult(
                status="not_found",
                query_url=traces_url,
                query_errors=[
                    {
                        "http_status": exc.response.status_code,
                        "body": exc.response.text[:200],
                    }
                ],
            )

        body = resp.json()
        data: list[dict[str, Any]] = body.get("data") or []
        last_errors = body.get("errors") or []
        last_query_url = str(getattr(resp, "url", traces_url))

        if data:
            present_services = {
                p.get("serviceName")
                for tr in data
                for p in tr.get("processes", {}).values()
            }
            # With require_services set, only return once ALL required services'
            # spans have appeared (server/DB spans lag the browser span by the
            # BatchSpanProcessor delay). Otherwise keep polling until the deadline.
            if not require_services or require_services.issubset(present_services):
                return TraceResult(
                    status="found",
                    traces=data,
                    query_errors=last_errors,
                    query_url=last_query_url,
                )

        if time.monotonic() >= deadline:
            break

        time.sleep(min(poll_interval, max(0, deadline - time.monotonic())))

    # Reachable, but no matching trace found before the deadline.
    return TraceResult(
        status="not_found",
        query_errors=last_errors,
        query_url=last_query_url,
    )


def fetch_latest_trace(service: str = "verify-kit") -> dict[str, Any] | None:
    """Return the most recent trace for ``service`` or ``None`` on miss/error.

    Args:
        service: Jaeger service name. Defaults to ``"verify-kit"`` to match the
            tracer created in ``harness.observability``.

    Returns:
        The first trace dict from ``response["data"]`` or ``None`` when the
        list is empty, the response is non-2xx, or the request errored out.
    """
    try:
        r = httpx.get(
            JAEGER_QUERY_URL,
            params={"service": service, "limit": 1},
            timeout=2.0,
        )
        r.raise_for_status()
        data = r.json().get("data", []) or []
        return data[0] if data else None
    except (httpx.RequestError, httpx.HTTPStatusError):
        return None


def render_trace_waterfall(trace: dict[str, Any], console: Console | None = None) -> None:
    """Render a single Jaeger trace as a Rich tree.

    Phase-2 scope is a flat tree of spans ordered by ``startTime`` with span
    duration shown in milliseconds. Parent threading via ``span.references``
    (``refType == "CHILD_OF"``) is best-effort: spans without a known parent
    attach at the root; circular reference detection is unnecessary for
    Jaeger's emitted shape.
    """
    console = console or Console()
    spans = sorted(
        trace.get("spans", []) or [],
        key=lambda s: s.get("startTime", 0),
    )

    trace_id = trace.get("traceID", "<unknown-trace>")
    root = Tree(f"trace: {trace_id}")

    # Index spans by spanID so we can attach children to parents.
    nodes: dict[str, Tree] = {}

    def _label(span: dict[str, Any]) -> str:
        op = span.get("operationName", "<unnamed>")
        dur_us = span.get("duration", 0) or 0
        return f"{op} [{dur_us / 1000:.1f}ms]"

    for span in spans:
        parent_id: str | None = None
        for ref in span.get("references", []) or []:
            if ref.get("refType") == "CHILD_OF":
                parent_id = ref.get("spanID")
                break
        if parent_id and parent_id in nodes:
            node = nodes[parent_id].add(_label(span))
        else:
            node = root.add(_label(span))
        sid = span.get("spanID")
        if sid:
            nodes[sid] = node

    console.print(root)


__all__ = [
    "fetch_latest_trace",
    "render_trace_waterfall",
    "poll_trace_by_tag",
    "TraceResult",
    "TraceResultStatus",
    "JAEGER_QUERY_URL",
]
