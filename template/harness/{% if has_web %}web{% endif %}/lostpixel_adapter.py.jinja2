"""harness.web.lostpixel_adapter — Parse Lost Pixel comparison output into ErrorEnvelope list.

# Verified signatures (2026-05-27):
#
# ErrorEnvelope (template/harness/models.py.jinja2:40):
#   code: str, message: str, hint: str | None, fix_command: str | None,
#   docs_url: str | None, file: str | None, line: int | None,
#   column: int | None, snippet: str | None
#   NOTE: NO "fixable" field on ErrorEnvelope (REVIEW-CHECKLIST §4).
#   Per-check fixability is declared via @register(fixable=True) in web.py.
#
# D-W01: baselines live in-git under web/.lost-pixel/baseline/
# D-W02: runs inside mcr.microsoft.com/playwright:v1.60.0-jammy (Docker-pinned)
# D-W03: git add IS the approval verb — literal string in fix_command.
#        Baseline update = git add web/.lost-pixel/baseline/<filename>
#        This surfaces via the existing zero-arg MCP fix_propose() tool.
#
# Lost Pixel OSS v3.x output:
#   comparison-results.json: array of result objects per snapshot
#   Each item has:
#     name: str (snapshot name, matches the data-lost-pixel-id or page name)
#     baselinePath: str (relative path to baseline PNG)
#     currentPath: str (relative path to current capture PNG)
#     diffPath: str | None (relative path to diff PNG, null if no diff)
#     diffPercentage: float (0.0-100.0, pixel diff %)
#     threshold: float (configured threshold, 0.0-100.0)
#     isNew: bool (no baseline exists yet)
#     isUpdated: bool (diff exceeds threshold)
#     isDeleted: bool (baseline exists but no current capture)
#
# lost-pixel-approve CLI shim (VIZ-03 — standalone CLI half):
#   Provides an argparse main() callable as `lost-pixel-approve` console script.
#   --dry-run (or no flag): preview mode — print baselines that would be approved.
#   --confirm: destructive mode — stage baselines via `git add <baselinePath>`.
#   MCP fix_propose --check=visual --approve wiring is DELIBERATELY DEFERRED to v0.3
#   (bead verify-kit-pc8). The MCP half depends on a per-check --approve arg shape
#   that does not exist in the current zero-arg fix_propose() signature.
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

from harness.models import ErrorEnvelope

_BASELINE_HINT = (
    "Run `just web-baseline` in Docker to capture a fresh baseline, "
    "review the diff PNG, then `git add` the new baseline if the change is intentional."
)

_DOCS_URL = "https://lost-pixel.com/docs"


def parse_lostpixel_output(lostpixel_dir: Path) -> list[ErrorEnvelope]:
    """Read Lost Pixel comparison-results.json and return ErrorEnvelope list.

    Args:
        lostpixel_dir: Path to the .lost-pixel/ directory inside the web/ dir
            (e.g. <cwd>/web/.lost-pixel/).

    Returns:
        List of ErrorEnvelope for each snapshot diff that exceeds the threshold.
        Returns empty list if all snapshots match (clean run) or if the
        comparison-results.json does not exist (no run yet).

    Raises:
        json.JSONDecodeError: if comparison-results.json is malformed.

    Note on D-W03: The fix_command for each envelope is the literal git add
    command that approves the new baseline. This command is surfaced via the
    existing zero-arg MCP fix_propose() tool (verified tools.py.jinja2:144).
    Per-finding fix_propose --check/--finding arg support deferred to v0.3
    (bead verify-kit-pc8).
    """
    results_path = lostpixel_dir / "comparison-results.json"

    if not results_path.exists():
        # No run yet — not a failure condition (Docker may not be available)
        return []

    raw: list[dict] = json.loads(results_path.read_text(encoding="utf-8"))
    envelopes: list[ErrorEnvelope] = []

    for item in raw:
        name: str = item.get("name", "unknown")
        diff_pct: float = float(item.get("diffPercentage", 0.0))
        threshold: float = float(item.get("threshold", 0.0))
        is_new: bool = bool(item.get("isNew", False))
        is_updated: bool = bool(item.get("isUpdated", False))
        is_deleted: bool = bool(item.get("isDeleted", False))

        # Only emit an envelope for snapshots that differ from baseline
        if not (is_new or is_updated or is_deleted):
            continue

        # Baseline-relative path for the diff PNG (used as file field + fix_command)
        diff_path: str | None = item.get("diffPath")
        baseline_path: str | None = item.get("baselinePath")

        if is_deleted:
            code = f"web.lost_pixel.deleted.{name}"
            message = f"Snapshot '{name}' baseline exists but no current capture found"
            fix_cmd = None  # deletion: investigate whether page was removed
        elif is_new:
            code = f"web.lost_pixel.new.{name}"
            message = f"Snapshot '{name}' has no baseline yet — run `just web-baseline` to create one"
            # New baseline: git add the baseline PNG
            baseline_rel = baseline_path or f"web/.lost-pixel/baseline/{name}.png"
            fix_cmd = f"git add {baseline_rel}"
        else:
            # isUpdated = diff exceeds threshold
            code = f"web.lost_pixel.diff.{name}"
            message = (
                f"Visual diff of {diff_pct:.1f}% on '{name}' "
                f"(threshold {threshold:.1f}%)"
            )
            # D-W03: git add is the approval verb — literal string surfaced via MCP fix_propose()
            baseline_rel = baseline_path or f"web/.lost-pixel/baseline/{name}.png"
            fix_cmd = f"git add {baseline_rel}"

        envelopes.append(ErrorEnvelope(
            code=code,
            message=message,
            hint=_BASELINE_HINT,
            fix_command=fix_cmd,
            docs_url=_DOCS_URL,
            # file: diff PNG path so MCP fix_propose() consumer can render the diff
            file=diff_path,
        ))

    return envelopes


def main(argv: list[str] | None = None) -> int:
    """CLI entry point for lost-pixel-approve (VIZ-03 — standalone CLI shim).

    Enumerates snapshots where isNew or isUpdated is True in
    comparison-results.json and either previews or stages them via git add.

    Default behaviour (no flags): acts as --dry-run (preview only, no mutation).
    --dry-run: print the git add commands that would run; exit 0.
    --confirm: run git add for each new/updated baseline; exit 0 on success.
    --dry-run and --confirm are mutually exclusive.

    MCP note: MCP fix_propose --check=visual --approve wiring is DELIBERATELY
    DEFERRED to v0.3 (bead verify-kit-pc8). That path requires a per-check
    --approve argument shape on fix_propose() that does not exist in the current
    zero-arg signature (verified tools.py.jinja2:144). This shim is the
    standalone CLI half of VIZ-03 only.
    """
    parser = argparse.ArgumentParser(
        prog="lost-pixel-approve",
        description=(
            "Preview or approve visual baselines from Lost Pixel comparison-results.json. "
            "Default (no flags) is dry-run — use --confirm to stage baselines via git add."
        ),
    )
    parser.add_argument(
        "--lostpixel-dir",
        type=Path,
        default=Path("web/.lost-pixel"),
        metavar="DIR",
        help="Path to the .lost-pixel/ directory (default: web/.lost-pixel)",
    )
    parser.add_argument(
        "--repo-root",
        type=Path,
        default=None,
        metavar="DIR",
        help=(
            "Repository root for git add cwd (default: resolved from --lostpixel-dir). "
            "Used as explicit cwd for subprocess git add (REVIEW-CHECKLIST §1)."
        ),
    )

    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument(
        "--dry-run",
        action="store_true",
        default=False,
        help="Preview baselines that would be approved without staging (default when no flag given).",
    )
    mode_group.add_argument(
        "--confirm",
        action="store_true",
        default=False,
        help="Stage each new/updated baseline via git add (destructive — mutates the git index).",
    )

    args = parser.parse_args(argv)

    # Default-safe: neither flag given → behave as --dry-run.
    is_dry_run = args.dry_run or (not args.dry_run and not args.confirm)
    is_confirm = args.confirm

    lostpixel_dir = args.lostpixel_dir
    results_path = lostpixel_dir / "comparison-results.json"

    if not results_path.exists():
        print(f"No comparison-results.json found at {results_path}. Nothing to approve.")
        return 0

    raw: list[dict] = json.loads(results_path.read_text(encoding="utf-8"))

    # Collect baselines eligible for approval (new or updated only).
    to_approve: list[str] = []
    for item in raw:
        is_new: bool = bool(item.get("isNew", False))
        is_updated: bool = bool(item.get("isUpdated", False))
        if not (is_new or is_updated):
            continue
        baseline_path: str | None = item.get("baselinePath")
        name: str = item.get("name", "unknown")
        if not baseline_path:
            baseline_path = f"web/.lost-pixel/baseline/{name}.png"
        to_approve.append(baseline_path)

    if not to_approve:
        print("All snapshots are clean — no baselines need approval.")
        return 0

    # Resolve the cwd for git add (REVIEW-CHECKLIST §1: never use bare relative Path).
    if args.repo_root is not None:
        repo_root = args.repo_root.resolve()
    else:
        # Walk up from lostpixel_dir until we find a .git directory.
        candidate = lostpixel_dir.resolve()
        repo_root = None
        for parent in [candidate, *candidate.parents]:
            if (parent / ".git").exists():
                repo_root = parent
                break
        if repo_root is None:
            # Fall back to cwd — document this rather than silently proceeding.
            repo_root = Path.cwd()
            print(
                f"Warning: no .git directory found above {lostpixel_dir}; "
                f"using cwd={repo_root} as git root.",
                file=sys.stderr,
            )

    if is_dry_run:
        print(f"Dry-run: {len(to_approve)} baseline(s) would be staged in {repo_root}:")
        for path in to_approve:
            print(f"  git add {path}")
        return 0

    # --confirm: stage each baseline via git add with an explicit cwd.
    errors: list[str] = []
    for path in to_approve:
        result = subprocess.run(  # noqa: S603
            ["git", "add", path],
            cwd=repo_root,
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            errors.append(f"git add {path} failed: {result.stderr.strip()}")
        else:
            print(f"Staged: {path}")

    if errors:
        for err in errors:
            print(f"Error: {err}", file=sys.stderr)
        return 1

    print(f"Approved {len(to_approve)} baseline(s).")
    return 0


__all__ = ["parse_lostpixel_output", "main"]


if __name__ == "__main__":
    raise SystemExit(main())
