"""harness.web.lostpixel_adapter — Interpret Lost Pixel OSS comparison output.

# Verified against lost-pixel v3.22.0 OSS local mode (2026-05-29):
#
# Lost Pixel OSS (no SaaS project id) signals comparison results via the
# process EXIT CODE, NOT a results file:
#   exit 0 → no differences (all snapshots match baseline)        → PASS
#   exit 1 → one or more snapshots differ (or have no baseline)   → FAIL
#   exit >1 → Lost Pixel/Docker crashed (handled by the check)
#
# On a differing run it writes one PNG per differing snapshot to
#   <web>/.lost-pixel/difference/<name>.png
# On a clean run it writes NOTHING beyond baseline/ and current/ PNGs.
#
# It does NOT write `comparison-results.json` — that is a Lost Pixel *platform*
# (SaaS) artifact and is never produced in OSS mode. (An earlier version of this
# adapter parsed a comparison-results.json that lost-pixel never emits, so the
# check could never go green on a cold path — verify-kit live-full caught it.)
#
# ErrorEnvelope (template/harness/models.py.jinja2:40):
#   code: str, message: str, hint: str | None, fix_command: str | None,
#   docs_url: str | None, file: str | None, line: int | None,
#   column: int | None, snippet: str | None
#   NOTE: NO "fixable" field on ErrorEnvelope (REVIEW-CHECKLIST §4).
#   Per-check fixability is declared via @register(fixable=True) in web.py.
#
# D-W01: baselines live in-git under web/.lost-pixel/baseline/
# D-W02: runs inside mcr.microsoft.com/playwright:v1.60.0-jammy (Docker-pinned)
# D-W03: git add IS the approval verb — literal string in fix_command.
#        Baseline update = git add web/.lost-pixel/baseline/<filename>
#        This surfaces via the existing zero-arg MCP fix_propose() tool.
#
# --require freshness is NOT this adapter's concern: the harness runner
# (harness/core.py) enforces it generically by asserting each required check
# carries the current process run_id (a cache-replay keeps a stale run_id and
# fails). The check always executes lost-pixel, so its exit code is fresh by
# construction. See tests/test_09_03_require_and_run_id.py.
#
# lost-pixel-approve CLI shim (VIZ-03 — standalone CLI half):
#   Provides an argparse main() callable as `lost-pixel-approve` console script.
#   Enumerates the snapshots that differed (difference/<name>.png) and either
#   previews or stages their baselines via git add.
#   --dry-run (or no flag): preview the git add commands; do not mutate.
#   --confirm: stage each baseline via git add.
#   MCP fix_propose --check=visual --approve wiring is DELIBERATELY DEFERRED to
#   v0.3 (bead verify-kit-pc8).
"""
from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path

from harness.models import ErrorEnvelope

_BASELINE_HINT = (
    "Review the diff PNG under web/.lost-pixel/difference/, then if the change is "
    "intentional run `just web-baseline` to regenerate the baseline and `git add` it."
)

_DOCS_URL = "https://lost-pixel.com/docs"


def _diff_pngs(lostpixel_dir: Path) -> list[Path]:
    """Return sorted difference PNGs written by a Lost Pixel comparison run."""
    difference_dir = lostpixel_dir / "difference"
    if not difference_dir.is_dir():
        return []
    return sorted(difference_dir.glob("*.png"))


def parse_lostpixel_output(lostpixel_dir: Path) -> list[ErrorEnvelope]:
    """Build an ErrorEnvelope per differing snapshot from the difference/ dir.

    Lost Pixel OSS signals diffs via exit code 1 and writes one PNG per differing
    snapshot to <lostpixel_dir>/difference/<name>.png. The web.lost_pixel check
    owns the exit-code interpretation and calls this only when the comparison
    exited 1 (diffs found); this turns each diff PNG into an ErrorEnvelope whose
    fix verb is `git add <baseline>` (D-W03).

    Args:
        lostpixel_dir: Path to the .lost-pixel/ directory inside the web/ dir
            (e.g. <cwd>/web/.lost-pixel/).

    Returns:
        One ErrorEnvelope per difference PNG. Empty list if none are present
        (which, on an exit-1 run, is itself unexpected — the check surfaces a
        generic diff envelope in that case).
    """
    envelopes: list[ErrorEnvelope] = []
    for png in _diff_pngs(lostpixel_dir):
        name = png.stem
        baseline_rel = f"web/.lost-pixel/baseline/{name}.png"
        envelopes.append(
            ErrorEnvelope(
                code=f"web.lost_pixel.diff.{name}",
                message=(
                    f"Visual diff on '{name}' — the current render differs from the "
                    f"baseline beyond the configured threshold. Diff image: {png}"
                ),
                hint=_BASELINE_HINT,
                # D-W03: git add is the approval verb — literal string surfaced via
                # the MCP fix_propose() tool.
                fix_command=f"git add {baseline_rel}",
                docs_url=_DOCS_URL,
                # file: diff PNG path so an MCP fix_propose() consumer can render it.
                file=str(png),
            )
        )
    return envelopes


def main(argv: list[str] | None = None) -> int:
    """CLI entry point for lost-pixel-approve (VIZ-03 — standalone CLI shim).

    Enumerates snapshots that differed (difference/<name>.png) and either previews
    or stages their baselines via git add.

    Default behaviour (no flags): acts as --dry-run (preview only, no mutation).
    --dry-run: print the git add commands that would run; exit 0.
    --confirm: run git add for each differing snapshot's baseline; exit 0 on success.
    --dry-run and --confirm are mutually exclusive.

    Approval flow: after reviewing the diff PNGs, run `just web-baseline` to
    regenerate the baselines, then this shim (or `git add`) stages them.

    MCP note: MCP fix_propose --check=visual --approve wiring is DELIBERATELY
    DEFERRED to v0.3 (bead verify-kit-pc8).
    """
    parser = argparse.ArgumentParser(
        prog="lost-pixel-approve",
        description=(
            "Preview or approve visual baselines for snapshots that differed in the "
            "last Lost Pixel run (web/.lost-pixel/difference/). Default (no flags) is "
            "dry-run — use --confirm to stage baselines via git add."
        ),
    )
    parser.add_argument(
        "--lostpixel-dir",
        type=Path,
        default=Path("web/.lost-pixel"),
        metavar="DIR",
        help="Path to the .lost-pixel/ directory (default: web/.lost-pixel)",
    )
    parser.add_argument(
        "--repo-root",
        type=Path,
        default=None,
        metavar="DIR",
        help=(
            "Repository root for git add cwd (default: resolved from --lostpixel-dir). "
            "Used as explicit cwd for subprocess git add (REVIEW-CHECKLIST §1)."
        ),
    )

    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument(
        "--dry-run",
        action="store_true",
        default=False,
        help=(
            "Preview baselines that would be approved without staging "
            "(default when no flag given)."
        ),
    )
    mode_group.add_argument(
        "--confirm",
        action="store_true",
        default=False,
        help="Stage each differing snapshot's baseline via git add (mutates the git index).",
    )

    args = parser.parse_args(argv)

    # Default-safe: neither flag given → behave as --dry-run.
    is_dry_run = args.dry_run or (not args.dry_run and not args.confirm)

    lostpixel_dir = args.lostpixel_dir

    # The snapshots needing approval are exactly those that differed.
    to_approve: list[str] = [
        f"web/.lost-pixel/baseline/{png.stem}.png" for png in _diff_pngs(lostpixel_dir)
    ]

    if not to_approve:
        print("All snapshots are clean — no baselines need approval.")
        return 0

    # Resolve the cwd for git add (REVIEW-CHECKLIST §1: never use bare relative Path).
    if args.repo_root is not None:
        repo_root = args.repo_root.resolve()
    else:
        # Walk up from lostpixel_dir until we find a .git directory.
        candidate = lostpixel_dir.resolve()
        repo_root = None
        for parent in [candidate, *candidate.parents]:
            if (parent / ".git").exists():
                repo_root = parent
                break
        if repo_root is None:
            # Fall back to cwd — document this rather than silently proceeding.
            repo_root = Path.cwd()
            print(
                f"Warning: no .git directory found above {lostpixel_dir}; "
                f"using cwd={repo_root} as git root.",
                file=sys.stderr,
            )

    if is_dry_run:
        print(f"Dry-run: {len(to_approve)} baseline(s) would be staged in {repo_root}:")
        for path in to_approve:
            print(f"  git add {path}")
        return 0

    # --confirm: stage each baseline via git add with an explicit cwd.
    errors: list[str] = []
    for path in to_approve:
        result = subprocess.run(  # noqa: S603
            ["git", "add", path],
            cwd=repo_root,
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            errors.append(f"git add {path} failed: {result.stderr.strip()}")
        else:
            print(f"Staged: {path}")

    if errors:
        for err in errors:
            print(f"Error: {err}", file=sys.stderr)
        return 1

    print(f"Approved {len(to_approve)} baseline(s).")
    return 0


__all__ = ["parse_lostpixel_output", "main"]


if __name__ == "__main__":
    raise SystemExit(main())
