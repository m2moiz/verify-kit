from __future__ import annotations
import json


def test_debug_state_returns_200_in_dev(client_dev, tmp_path):
    # tmp_path here is the SAME tmp_path used by app_dev fixture.
    state_file = tmp_path / ".verify" / "state.json"
    state_file.write_text(json.dumps({"last_run": "ok", "checks": 5}))
    r = client_dev.get("/__debug/state")
    assert r.status_code == 200
    assert r.json() == {"last_run": "ok", "checks": 5}


def test_debug_state_returns_404_when_no_state_file(client_dev):
    r = client_dev.get("/__debug/state")
    assert r.status_code == 404  # state.json not created in this test


def test_debug_state_returns_404_in_prod(client_prod):
    r = client_prod.get("/__debug/state")
    # Router is not mounted in prod -> route-not-found 404
    assert r.status_code == 404


def test_debug_events_streams_lines(client_dev, tmp_path):
    events_file = tmp_path / ".verify" / "events.jsonl"
    events_file.write_text('{"a": 1}\n{"b": 2}\n')
    with client_dev.stream("GET", "/__debug/events") as r:
        assert r.status_code == 200
        body = "".join(r.iter_text())
        assert "verify-event" in body
        assert '"a": 1' in body or '\\"a\\": 1' in body  # SSE may JSON-escape
