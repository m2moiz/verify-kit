import os
import subprocess

import pytest_asyncio
from testcontainers.postgres import PostgresContainer


def _docker_daemon_running() -> bool:
    """Return True iff `docker info` exits 0 within 30s.

    `shutil.which("docker")` returns True even when the daemon is stopped,
    leading to false-pass / hang in Testcontainers — we probe the daemon
    explicitly instead.

    Timeout is 30s (not 5s) because Docker Desktop on macOS has a slow
    first-call path through its virtualization proxy; a 5s budget produces
    flaky 'docker daemon not running' false positives even when healthy.
    """
    try:
        r = subprocess.run(
            ["docker", "info"],
            capture_output=True,
            timeout=30,
        )
        return r.returncode == 0
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


@pytest.fixture(scope="session")
def pg_container():
    """Session-scoped Postgres container. Image cached after first pull.

    Uses postgres:16-alpine to match docker-compose.yml. Calls `alembic upgrade head`
    against the container URL once it starts. Skips cleanly if the Docker daemon
    is not running.
    """
    if not _docker_daemon_running():
        pytest.skip(
            "Docker daemon not running (docker info failed) — skipping Testcontainers tests"
        )

    container = PostgresContainer("postgres:16-alpine")
    container.start()
    # testcontainers >=4.7 defaults to driver="psycopg2"; pass driver explicitly so
    # the URL is "postgresql+asyncpg://..." (matches the async engine + avoids the
    # silent .replace no-op when the source URL is already "postgresql+psycopg2://").
    db_url = container.get_connection_url(driver="asyncpg")

    # Run migrations from the scratch root — REVIEW-CHECKLIST §1: explicit cwd.
    # __file__ = scratch/tests/backend/conftest.py, so:
    #   .parent       = scratch/tests/backend/
    #   .parent.parent = scratch/tests/
    #   .parent.parent.parent = scratch/   <-- scaffold root where alembic.ini lives
    # Using only 2 parents would resolve to scratch/tests/ (no alembic.ini there).
    scratch_root = Path(__file__).resolve().parent.parent.parent
    env = {**os.environ, "DATABASE_URL": db_url}
    subprocess.run(
        ["uv", "run", "alembic", "upgrade", "head"],
        cwd=scratch_root,
        env=env,
        check=True,
        timeout=120,
    )

    yield db_url
    container.stop()


