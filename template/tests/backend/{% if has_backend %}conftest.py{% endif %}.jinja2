@pytest.fixture
def client_dev(app_dev):
    # CRITICAL: use TestClient as a context manager so Starlette/FastAPI
    # invokes the lifespan handler. Bare `TestClient(app)` SKIPS lifespan,
    # so `app.state.settings` (set inside lifespan) is unbound and every
    # route that reads `request.app.state.settings` raises AttributeError.
    # See https://fastapi.tiangolo.com/advanced/testing-events/.
    #
    # Override require_auth for route tests; auth itself is covered by
    # test_phase06_auth_polarity.py at repo root.
    app_dev.dependency_overrides[require_auth] = lambda: None
    with TestClient(app_dev) as client:
        yield client
    app_dev.dependency_overrides.clear()


