from __future__ import annotations
from pathlib import Path
import pytest
from fastapi.testclient import TestClient
from app.main import create_app


@pytest.fixture
def app_dev(tmp_path: Path):
    """FastAPI app rooted at tmp_path with ENV=dev."""
    (tmp_path / ".env").write_text("ENV=dev\nPROFILE_ENABLED=true\n")
    (tmp_path / ".verify").mkdir(exist_ok=True)
    return create_app(cwd=tmp_path)


@pytest.fixture
def app_prod(tmp_path: Path):
    """FastAPI app rooted at tmp_path with ENV=prod."""
    (tmp_path / ".env").write_text("ENV=prod\nPROFILE_ENABLED=false\n")
    return create_app(cwd=tmp_path)


@pytest.fixture
def client_dev(app_dev):
    # CRITICAL (cycle 3 — Codex HIGH B): use TestClient as a context manager
    # so Starlette/FastAPI invokes the lifespan handler. Bare `TestClient(app)`
    # SKIPS lifespan, so `app.state.settings` (set inside lifespan) is unbound
    # and every route that reads `request.app.state.settings` raises AttributeError.
    # See https://fastapi.tiangolo.com/advanced/testing-events/.
    with TestClient(app_dev) as client:
        yield client


@pytest.fixture
def client_prod(app_prod):
    # Same lifespan-context requirement — see client_dev docstring.
    with TestClient(app_prod) as client:
        yield client

