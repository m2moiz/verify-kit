"""Polarity test for has_fastapi_mcp."""

from __future__ import annotations

{% if has_fastapi_mcp %}

def test_fastapi_mcp_is_mounted(client_dev):
    """When has_fastapi_mcp=true, FastApiMCP(app).mount() exposes /mcp."""
    # The /mcp endpoint is added by FastApiMCP(app).mount(); a HEAD or GET should
    # return a non-404 status (200 or 405 depending on the SSE/HTTP shape).
    r = client_dev.get("/mcp")
    assert r.status_code != 404, "expected /mcp to be mounted, got 404"


def test_mcp_tools_introspection(client_dev):
    """The FastApiMCP layer exposes a tools enumeration. Probe its public URL.

    The exact path depends on fastapi-mcp version; check both common shapes.
    """
    candidates = ["/mcp/tools", "/mcp/tool_list", "/mcp"]
    statuses = []
    for path in candidates:
        statuses.append(client_dev.get(path).status_code)
    # At least one candidate must return non-404.
    assert any(s != 404 for s in statuses), f"none of {candidates} returned non-404: {statuses}"
{% else %}

def test_mcp_route_not_mounted_when_flag_false(client_dev):
    """When has_fastapi_mcp=false, /mcp returns 404."""
    r = client_dev.get("/mcp")
    assert r.status_code == 404
{% endif %}
