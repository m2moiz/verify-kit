"""Per-test fixtures for the LLM test suite.

Two autouse function-scope fixtures:

1. ``_reset_llm_cost`` — calls ``reset_cost_accumulator()`` before each
   test body runs, so ``@cost_budget`` accumulator state cannot leak
   between tests (the accumulator is a contextvar — fine within a single
   test but not across them).

2. ``_skip_when_no_cassette`` — first-run-clean discipline. For any
   test marked ``@pytest.mark.vcr``: if the
   active record_mode is ``"none"`` (the CI default — see
   ``tests/conftest.py``) AND the expected cassette file does not yet
   exist on disk, the fixture calls ``pytest.skip(...)`` so the test
   does not attempt a live API call.

   Crucially: when ``--record-mode=once`` is passed on the CLI (used
   by ``just refresh-cassettes``), the fixture must NOT skip — VCR
   must proceed and record the cassette. The record-mode gate contract
   is exercised by ``tests/llm/test_skip_fixture_contract.py``.
"""

from __future__ import annotations

import asyncio
from pathlib import Path

import httpx
import pytest

from harness.llm import reset_cost_accumulator


@pytest.fixture(autouse=True)
def _reset_llm_cost():
    """Clear the per-process cost accumulator before each test."""
    reset_cost_accumulator()
    yield


@pytest.fixture(autouse=True)
def _litellm_vcr_httpx_session(request):
    """Use a VCR-patchable async HTTP client for cassette-backed LiteLLM calls."""
    marker = request.node.get_closest_marker("vcr")
    if marker is None:
        yield
        return

    import litellm

    previous_aclient_session = getattr(litellm, "aclient_session", None)
    client = httpx.AsyncClient(follow_redirects=True)
    litellm.aclient_session = client
    try:
        yield
    finally:
        litellm.aclient_session = previous_aclient_session
        asyncio.run(client.aclose())


@pytest.fixture(autouse=True)
def _skip_when_no_cassette(request):
    """Skip vcr-marked tests when their cassette is missing in default mode.

    Default record_mode is ``"none"`` (CI; see tests/conftest.py vcr_config).
    In that mode a missing cassette would make VCR raise; we skip cleanly
    instead so ``uv run pytest tests/llm/`` on a fresh scaffold exits 0.

    When the CLI flag ``--record-mode=once`` is in effect (the mode
    ``just refresh-cassettes`` runs), this fixture MUST NOT skip — VCR
    needs to proceed and write the cassette. Reversing this guard would
    make the refresh recipe self-defeating.
    """
    marker = request.node.get_closest_marker("vcr")
    if marker is None:
        yield
        return

    # Read the effective record_mode. CLI flag wins over fixture default
    # (pytest-recording's documented precedence: CLI > fixture).
    cli_mode = request.config.getoption("--record-mode", default=None)
    if cli_mode and cli_mode != "none":
        # Recording path is active — let VCR run.
        yield
        return

    # Fall back to the fixture-level default if the CLI flag was not given.
    fixture_mode = "none"
    try:
        cfg = request.getfixturevalue("vcr_config")
        if isinstance(cfg, dict):
            fixture_mode = cfg.get("record_mode", "none")
    except Exception:
        # If vcr_config is not visible, assume the CI default.
        fixture_mode = "none"

    if fixture_mode != "none":
        # Some non-default record_mode is active via the fixture — let VCR run.
        yield
        return

    # Default-mode path: skip if the cassette is missing.
    test_module = request.node.module.__name__.rsplit(".", 1)[-1]
    cassette_path = Path(__file__).parent / "cassettes" / test_module / f"{request.node.name}.yaml"
    if not cassette_path.exists():
        pytest.skip(
            f"cassette not recorded: {cassette_path}. Run `just refresh-cassettes` to populate."
        )
    yield
