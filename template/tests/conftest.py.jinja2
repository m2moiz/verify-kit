# ── LLM cassette scrubbing (Pitfall 2: load BEFORE first cassette write) ──────
#
# vcrpy's default config does NOT scrub Authorization / x-api-key headers, so
# the first cassette recorded against a live LLM API will ship a real bearer
# token to disk. This fixture installs filter_headers + a before_record_request
# callable so the scrub happens BEFORE the cassette file is written.
#
# record_mode discipline:
#   - pytest-recording's own record_mode fixture defaults to "none" — CI and
#     any default `pytest tests/llm/` run refuses to record; missing cassettes
#     raise (or are skipped by the autouse `_skip_when_no_cassette` fixture in
#     tests/llm/conftest.py).
#   - Developers re-record via the CLI flag `pytest --record-mode=once`. Do not
#     set "record_mode" in vcr_config: pytest-recording gives vcr_config higher
#     precedence than the CLI flag, which would make refresh-cassettes unable to
#     write new cassette files.
_LLM_SCRUB_HEADERS = (
    "authorization",
    "x-api-key",
    "anthropic-api-key",
    "openai-api-key",
    "openai-organization",
    "x-langfuse-public-key",
)


@pytest.fixture(scope="module")
def vcr_config() -> dict:
    """vcrpy config for LLM cassette recording — scrubs credential headers.

    See module-level _LLM_SCRUB_HEADERS for the full list. Two mechanisms run
    side-by-side (defense-in-depth — a single typo in either should not leak):
      1. ``filter_headers`` list-of-tuple: vcrpy replaces matching headers with
         "REDACTED" at the wire level.
      2. ``before_record_request`` callable: a second pass that walks the
         request.headers mapping case-insensitively and overwrites any match.

    record_mode is intentionally omitted here. pytest-recording's record_mode
    fixture defaults to "none", and the CLI flag --record-mode=once overrides
    that fixture value when `just refresh-cassettes` re-records cassettes.
    """

    def _scrub(request):
        # Case-insensitive scrub — vcrpy normalizes header names but cassettes
        # written by older releases can carry mixed-case keys.
        for header_name in list(request.headers):
            if header_name.lower() in _LLM_SCRUB_HEADERS:
                request.headers[header_name] = "REDACTED"
        return request

    return {
        "filter_headers": [(h, "REDACTED") for h in _LLM_SCRUB_HEADERS],
        "before_record_request": _scrub,
        "filter_query_parameters": [("api_key", "REDACTED")],
    }
