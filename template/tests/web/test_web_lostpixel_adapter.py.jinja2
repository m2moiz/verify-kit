"""Unit tests for harness.web.lostpixel_adapter.

CONTRACT CONFORMANCE TEST — REVIEW-CHECKLIST §4 API-surface drift guard.

Lost Pixel OSS signals comparison results via the process EXIT CODE, not a
results file. On a differing run it writes one PNG per differing snapshot to
web/.lost-pixel/difference/<name>.png. The adapter turns those PNGs into
ErrorEnvelopes; the check (web.py) owns the exit-code interpretation.

D-W01: baselines live in-git under web/.lost-pixel/baseline/
D-W03: fix_command is `git add web/.lost-pixel/baseline/<file>` (literal string)
       This command surfaces via the zero-arg MCP fix_propose() tool.

Verified shapes:
  ErrorEnvelope: NO "fixable" field (per-check fixability on @register)
  code format: web.lost_pixel.diff.<name>
  fix_command: "git add web/.lost-pixel/baseline/<name>.png"
  file: diff PNG path (for MCP fix_propose() consumer rendering)
"""
from __future__ import annotations

import re
from pathlib import Path

from harness.web.lostpixel_adapter import main, parse_lostpixel_output

# ── Fixtures ──────────────────────────────────────────────────────────────────


def _make_diff(tmp_path: Path, *names: str) -> Path:
    """Create a .lost-pixel/ dir with one difference/<name>.png per name."""
    lp_dir = tmp_path / ".lost-pixel"
    difference = lp_dir / "difference"
    difference.mkdir(parents=True, exist_ok=True)
    for name in names:
        (difference / f"{name}.png").write_bytes(b"\x89PNG\r\n")  # minimal stub
    return lp_dir


# ── Tests: parse_lostpixel_output ───────────────────────────────────────────────


def test_parse_lostpixel_diff_emits_envelope(tmp_path: Path) -> None:
    """A difference PNG → one envelope with the diff code."""
    lp_dir = _make_diff(tmp_path, "gallery-full")
    envelopes = parse_lostpixel_output(lp_dir)

    assert len(envelopes) == 1
    assert envelopes[0].code == "web.lost_pixel.diff.gallery-full", (
        f"Expected code 'web.lost_pixel.diff.gallery-full', got {envelopes[0].code!r}"
    )


def test_parse_lostpixel_fix_command_is_git_add(tmp_path: Path) -> None:
    """D-W03: fix_command is 'git add web/.lost-pixel/baseline/<name>.png'."""
    lp_dir = _make_diff(tmp_path, "gallery-full")
    envelopes = parse_lostpixel_output(lp_dir)

    assert envelopes[0].fix_command == "git add web/.lost-pixel/baseline/gallery-full.png", (
        f"D-W03 violation: got {envelopes[0].fix_command!r}"
    )


def test_parse_lostpixel_file_is_diff_png(tmp_path: Path) -> None:
    """file field is the diff PNG path for MCP fix_propose() rendering."""
    lp_dir = _make_diff(tmp_path, "gallery-full")
    envelopes = parse_lostpixel_output(lp_dir)

    assert envelopes[0].file is not None
    assert envelopes[0].file.endswith("difference/gallery-full.png"), (
        f"file field should be the diff PNG path, got: {envelopes[0].file!r}"
    )


def test_parse_lostpixel_multiple_diffs_sorted(tmp_path: Path) -> None:
    """Multiple difference PNGs → one envelope each, sorted by name."""
    lp_dir = _make_diff(tmp_path, "zeta", "alpha")
    envelopes = parse_lostpixel_output(lp_dir)

    assert [e.code for e in envelopes] == [
        "web.lost_pixel.diff.alpha",
        "web.lost_pixel.diff.zeta",
    ]


def test_parse_lostpixel_no_difference_dir_returns_empty(tmp_path: Path) -> None:
    """No difference/ dir (clean run) → empty list (not an error)."""
    lp_dir = tmp_path / ".lost-pixel"
    lp_dir.mkdir()
    assert parse_lostpixel_output(lp_dir) == []


def test_parse_lostpixel_empty_difference_dir_returns_empty(tmp_path: Path) -> None:
    """An empty difference/ dir (no PNGs) → empty list."""
    lp_dir = tmp_path / ".lost-pixel"
    (lp_dir / "difference").mkdir(parents=True)
    assert parse_lostpixel_output(lp_dir) == []


# ── Tests: REVIEW-CHECKLIST §4 contract guards ──────────────────────────────────


def test_parse_lostpixel_no_fixable_kwarg_in_adapter() -> None:
    """REVIEW-CHECKLIST §4: adapter must not pass fixable= to ErrorEnvelope(...)."""
    import harness.web.lostpixel_adapter as _mod

    src = Path(_mod.__file__).read_text(encoding="utf-8")
    match = re.search(r"ErrorEnvelope\([^)]*fixable", src)
    assert match is None, (
        f"Found ErrorEnvelope(...fixable=...) at char {match.start()} in "
        f"lostpixel_adapter.py — REVIEW-CHECKLIST §4 violation."
    )


def test_parse_lostpixel_envelopes_have_no_fixable_attr(tmp_path: Path) -> None:
    """Resulting envelopes have no 'fixable' attribute."""
    lp_dir = _make_diff(tmp_path, "gallery-full")
    for env in parse_lostpixel_output(lp_dir):
        assert not hasattr(env, "fixable"), (
            "ErrorEnvelope has a 'fixable' attribute — model changed. "
            "Read REVIEW-CHECKLIST §4."
        )


# ── Tests: lost-pixel-approve CLI shim (VIZ-03) ─────────────────────────────────


def test_approve_shim_dry_run_lists_baselines(tmp_path: Path, capsys) -> None:
    """Dry-run (default) lists `git add` for each differing snapshot's baseline."""
    lp_dir = _make_diff(tmp_path, "gallery-full")
    rc = main(["--lostpixel-dir", str(lp_dir), "--repo-root", str(tmp_path)])
    out = capsys.readouterr().out
    assert rc == 0
    assert "git add web/.lost-pixel/baseline/gallery-full.png" in out


def test_approve_shim_clean_run_nothing_to_approve(tmp_path: Path, capsys) -> None:
    """No difference PNGs → 'nothing to approve' message, exit 0."""
    lp_dir = tmp_path / ".lost-pixel"
    lp_dir.mkdir()
    rc = main(["--lostpixel-dir", str(lp_dir), "--repo-root", str(tmp_path)])
    out = capsys.readouterr().out
    assert rc == 0
    assert "clean" in out.lower() or "no baselines" in out.lower()
